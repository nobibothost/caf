<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDD Manager</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .form-section { display: none; }
        .form-section.active { display: block; animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
        .divider { height: 1px; background: #e2e8f0; margin: 20px 0; position: relative; }
        .divider span { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 0 10px; color: #64748b; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
        .section-label { font-size: 0.95rem; font-weight: 700; color: var(--primary); margin-bottom: 12px; display: block; }
        .flatpickr-input { background-color: #f8fafc !important; }
    </style>
</head>
<body>
    
    <nav class="navbar">
        <div class="logo">
            <i class="ri-file-paper-2-fill"></i> PDD<span class="highlight">Tracker</span>
        </div>
        <a href="#" class="logout-btn" onclick="openConfirmModal(event, '/logout', 'logout')"><i class="ri-logout-box-r-line"></i></a>
    </nav>

    <div class="container">
        <div class="section-title" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
            <div>
                <h2 style="margin: 0;"><i class="ri-bill-line"></i> Pending Bills</h2>
                <p class="subtitle" style="margin: 0;">Customers with pending bill payment.</p>
            </div>
            
            <% if (pendingBills.length > 0) { %>
                <form action="/pay-all-bills" method="POST" onsubmit="openConfirmModal(event, this, 'payAll')">
                    <button type="submit" style="background: #10b981; color: white; border: none; padding: 10px 15px; border-radius: 8px; font-weight: 600; display: flex; align-items: center; gap: 5px; cursor: pointer; box-shadow: 0 2px 4px rgba(16, 185, 129, 0.3);">
                        <i class="ri-check-double-line"></i> Mark All Paid
                    </button>
                </form>
            <% } %>
        </div>

        <div class="search-box" style="margin-bottom: 20px;">
            <i class="ri-search-line"></i>
            <input type="text" id="searchInput" onkeyup="filterList()" placeholder="Quick filter on this page...">
        </div>

        <div class="grid-layout">
            <% if (pendingBills.length === 0) { %>
                <div class="empty-state">
                    <div class="icon-box"><i class="ri-file-check-line"></i></div>
                    <h3>No Pendings!</h3>
                    <p>All bills are paid for this cycle.</p>
                </div>
            <% } else { %>
                <% pendingBills.forEach(customer => { %>
                    <div class="card search-item" style="border-left: 4px solid var(--primary);">
                        <div class="card-top">
                            <span class="badge" style="background: rgba(79, 70, 229, 0.1); color: var(--primary);">
                                Bill Date: <%= customer.billDate %>th
                            </span>
                            <span class="date-tag" style="color: #ef4444; font-weight: 600;">Due</span>
                        </div>
                        
                        <% if (customer.category === 'Family') { %>
                            <div class="family-wrapper">
                                <div class="family-section primary-sec">
                                    <span class="fs-label primary-label">Primary Connection</span>
                                    <div class="fs-info">
                                        <h4><%= customer.linkedPrimaryName || 'Unknown' %></h4>
                                        <p><i class="ri-smartphone-line"></i> <%= customer.linkedPrimaryNumber %></p>
                                    </div>
                                    <div class="fs-actions">
                                        <a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i> WA</a>
                                        <a href="tel:<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i> Call</a>
                                    </div>
                                </div>
                                <div class="family-section secondary-sec">
                                    <span class="fs-label secondary-label">Secondary (This SIM)</span>
                                    <div class="fs-info">
                                        <h4><%= customer.name %></h4>
                                        <p><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                                    </div>
                                    <div class="fs-actions">
                                        <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i> WA</a>
                                        <a href="tel:<%= customer.mobile %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i> Call</a>
                                    </div>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="card-body">
                                <h3 class="customer-name"><%= customer.name %></h3>
                                <p class="meta-info mobile-txt" style="color: var(--text-main); font-weight: 500;">
                                    <i class="ri-smartphone-line"></i> <%= customer.mobile %>
                                </p>
                                <p class="meta-info">
                                    <i class="ri-calendar-event-line"></i> 
                                    Bill Cycle: <%= customer.cycleKey %>
                                </p>
                            </div>
                            <div class="card-actions">
                                <a href="tel:<%= customer.mobile %>" class="btn-call"><i class="ri-phone-fill"></i> Call</a>
                                <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp"><i class="ri-whatsapp-line"></i> WhatsApp</a>
                            </div>
                        <% } %>

                        <div class="card-actions" style="margin-top: 12px; border-top: 1px solid #f1f5f9; padding-top: 10px;">
                            <form action="/pay-bill/<%= customer._id %>" method="POST" style="flex: 1;" onsubmit="openConfirmModal(event, this, 'pay')">
                                <input type="hidden" name="cycleKey" value="<%= customer.cycleKey %>">
                                <button type="submit" class="btn-check" style="background: var(--primary); color: white; width: 100%;">
                                    <i class="ri-check-double-line"></i> Mark Paid (Full Card)
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <div id="customConfirmModal" class="modal-overlay" style="display: none; z-index: 10000;">
        <div class="modal-card" style="text-align: center; max-width: 340px; padding: 30px 20px;">
            <div id="confirmIcon" class="confirm-icon"></div>
            <h3 id="confirmTitle" style="margin-bottom: 10px; font-size: 1.3rem;"></h3>
            <p id="confirmMessage" style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5;"></p>
            <div class="confirm-actions">
                <button type="button" class="btn-confirm-cancel" onclick="closeConfirmModal()">Cancel</button>
                <button type="button" id="confirmYesBtn" class="btn-confirm-yes">Yes</button>
            </div>
        </div>
    </div>

    <div class="bottom-nav">
        <a href="/" class="nav-item"><i class="ri-home-4-line"></i><span>Home</span></a>
        <a href="/all" class="nav-item"><i class="ri-list-check"></i><span>All</span></a>
        <a href="/pdd" class="nav-item active"><i class="ri-file-paper-2-fill"></i><span>PDD</span></a>
        <div class="nav-fab" onclick="window.location.href='/'"><i class="ri-add-line"></i></div>
        <a href="/search" class="nav-item"><i class="ri-search-line"></i><span>Search</span></a>
        <a href="/manage" class="nav-item"><i class="ri-edit-2-line"></i><span>Edit</span></a>
        <a href="/analytics" class="nav-item"><i class="ri-pie-chart-line"></i><span>Analysis</span></a>
    </div>

    <script>
        function filterList() { 
            let input = document.getElementById('searchInput').value.toLowerCase(); 
            let items = document.getElementsByClassName('search-item'); 
            for (let i = 0; i < items.length; i++) { 
                let text = items[i].innerText.toLowerCase(); 
                if (text.includes(input)) items[i].style.display = ""; 
                else items[i].style.display = "none"; 
            } 
        }

        // --- CUSTOM CONFIRM MODAL LOGIC ---
        let formToSubmit = null;
        function openConfirmModal(event, element, actionType) {
            event.preventDefault();
            formToSubmit = element;
            
            const titleEl = document.getElementById('confirmTitle');
            const msgEl = document.getElementById('confirmMessage');
            const iconEl = document.getElementById('confirmIcon');
            const yesBtn = document.getElementById('confirmYesBtn');

            yesBtn.className = 'btn-confirm-yes';
            
            if (actionType === 'pay') {
                titleEl.innerText = "Mark as Paid?";
                msgEl.innerText = "Are you sure you want to mark this bill as paid?";
                iconEl.innerHTML = '<i class="ri-money-rupee-circle-line" style="color: #10b981;"></i>';
                yesBtn.classList.add('btn-confirm-success');
                yesBtn.innerText = "Yes, Paid";
            } else if (actionType === 'payAll') {
                titleEl.innerText = "Mark ALL Paid?";
                msgEl.innerText = "Are you sure you want to mark ALL pending bills as paid for this cycle?";
                iconEl.innerHTML = '<i class="ri-checkbox-multiple-line" style="color: #10b981;"></i>';
                yesBtn.classList.add('btn-confirm-success');
                yesBtn.innerText = "Yes, Mark All";
            } else if (actionType === 'logout') {
                titleEl.innerText = "Secure Logout?";
                msgEl.innerText = "Are you sure you want to end your session?";
                iconEl.innerHTML = '<i class="ri-logout-circle-line" style="color: #ef4444;"></i>';
                yesBtn.classList.add('btn-confirm-danger');
                yesBtn.innerText = "Yes, Logout";
            }

            document.getElementById('customConfirmModal').style.display = 'flex';
            setTimeout(() => document.getElementById('customConfirmModal').classList.add('active'), 10);
        }

        function closeConfirmModal() {
            document.getElementById('customConfirmModal').classList.remove('active');
            setTimeout(() => document.getElementById('customConfirmModal').style.display = 'none', 300);
            formToSubmit = null;
        }

        document.getElementById('confirmYesBtn').addEventListener('click', function() {
            if (formToSubmit) {
                if (typeof formToSubmit === 'string') {
                    window.location.href = formToSubmit;
                } else {
                    let returnInput = formToSubmit.querySelector('input[name="returnUrl"]');
                    if (!returnInput) {
                        returnInput = document.createElement('input'); returnInput.type = 'hidden'; returnInput.name = 'returnUrl'; formToSubmit.appendChild(returnInput);
                    }
                    returnInput.value = window.location.pathname + window.location.search;
                    sessionStorage.setItem('scrollPos', window.scrollY);
                    sessionStorage.setItem('scrollPath', window.location.pathname + window.location.search);
                    formToSubmit.submit();
                }
            }
        });

        window.onclick = function(event) { if(event.target == document.getElementById('customConfirmModal')) closeConfirmModal(); }

        window.addEventListener('DOMContentLoaded', () => {
            const scrollPath = sessionStorage.getItem('scrollPath');
            const currentPath = window.location.pathname + window.location.search;
            if (scrollPath === currentPath) {
                const scrollPos = sessionStorage.getItem('scrollPos');
                if (scrollPos) setTimeout(() => window.scrollTo(0, parseInt(scrollPos)), 50);
            }
            sessionStorage.removeItem('scrollPos'); sessionStorage.removeItem('scrollPath');
        });
    </script>
</body>
</html>