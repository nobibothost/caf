<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDD Tracker</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <nav class="navbar"><div class="logo"><i class="ri-file-paper-2-line"></i> PDD<span class="highlight">Tracker</span></div><a href="#" class="logout-btn" onclick="openConfirmModal(event, null, 'logout')"><i class="ri-logout-box-r-line"></i></a></nav>

    <div id="app-main">
        <div class="container">
            <div class="section-title" style="margin-bottom: 25px;"><h2><i class="ri-file-paper-2-fill" style="color: #3b82f6;"></i> <%= headerTitle %></h2><p class="subtitle">Track and follow up on pending bill payments.</p></div>
            
            <% if(pendingBills.length > 0) { %>
                <div style="background: #fffbfa; border: 1px solid #fed7aa; border-left: 4px solid #f59e0b; padding: 16px 20px; border-radius: 12px; margin-bottom: 20px; display: flex; gap: 15px; align-items: flex-start; box-shadow: 0 4px 6px rgba(245, 158, 11, 0.05);">
                    <i class="ri-error-warning-fill" style="color: #f59e0b; font-size: 1.6rem; margin-top: 2px;"></i>
                    <div style="flex: 1;"><strong style="color: #92400e; display: block; font-size: 0.95rem; margin-bottom: 4px;">Action Required</strong><span style="color: #b45309; font-size: 0.85rem; line-height: 1.4;">You have <b><%= pendingBills.length %></b> pending bills right now. Make sure to follow up to prevent loss of retention payout.</span></div>
                </div>
                <form action="/pay-all-bills" method="POST" style="margin-bottom: 25px;" onsubmit="openConfirmModal(event, this, 'payAll')"><button type="submit" class="btn-submit" style="background: #f8fafc; color: #10b981; border: 1px solid #10b981; box-shadow: 0 2px 4px rgba(16,185,129,0.1);"><i class="ri-checkbox-multiple-fill"></i> Mark All as Paid (Clear List)</button></form>
            <% } else { %>
                <div style="text-align: center; padding: 50px 20px; background: white; border-radius: 20px; border: 1px dashed #cbd5e1; margin-top: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.02);">
                    <div style="width: 80px; height: 80px; background: #d1fae5; color: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; margin: 0 auto 20px auto; box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.2);"><i class="ri-shield-check-fill"></i></div>
                    <h3 style="margin: 0 0 10px 0; color: #0f172a; font-size: 1.4rem;">All Caught Up!</h3><p style="margin: 0; color: #64748b; font-size: 0.95rem;">There are no pending first bill payments right now. Amazing work!</p>
                </div>
            <% } %>

            <div class="grid-layout" id="customerList" data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>">
                <% pendingBills.forEach(customer => { %>
                    <div class="card search-item" style="position: relative; overflow: hidden; border: 1px solid #fee2e2; box-shadow: 0 4px 6px rgba(239, 68, 68, 0.05);">
                        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: #ef4444;"></div>
                        <div class="card-top" style="margin-top: 5px;">
                            <div style="display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                <% if (customer.category === 'Family') { %> <span class="badge badge-Family">Family</span> <% } else { %> <span class="badge badge-<%= customer.category %>"><%= customer.category %></span> <% } %>
                                <% if(customer.plan) { %><span class="badge" style="background: #f3f4f6; color: #475569; font-size: 0.65rem;">₹<%= customer.plan %></span><% } %>
                                <span class="badge" style="background: #fee2e2; color: #dc2626;"><i class="ri-bill-line"></i> Bill Due: <%= customer.billDate %>th</span>
                            </div>
                        </div>

                        <% if (customer.category === 'Family') { %>
                            <div class="family-wrapper" style="border-color: #fca5a5; background: #fff5f5;">
                                <div class="family-section secondary-sec" style="border: none;"><span class="fs-label secondary-label" style="color: #dc2626;">Secondary (This SIM) <span class="badge badge-<%= customer.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.subType %></span></span><div class="fs-info"><h4 class="customer-name"><%= customer.name %></h4><p class="mobile-txt"><%= customer.mobile %></p></div></div>
                            </div>
                        <% } else { %>
                            <div class="card-body"><h3 class="customer-name"><%= customer.name %></h3><p class="meta-info mobile-txt" style="margin-bottom: 10px;"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p></div>
                        <% } %>

                        <div class="card-actions" style="margin-bottom: 15px;"><button type="button" class="btn-whatsapp" style="flex: 1;" onclick="openWaModal('<%= customer.mobile %>', '<%= customer.name %>', 'pdd', '<%= customer.billDate %>')"><i class="ri-whatsapp-line"></i> Remind on WA</button><a href="tel:<%= customer.mobile %>" class="btn-call" style="flex: 1;"><i class="ri-phone-fill"></i> Call</a></div>

                        <div class="card-actions" style="margin-top: 0;">
                            <% if (customer.remarks && customer.remarks.trim() !== "") { %> <button class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)"><i class="ri-sticky-note-fill"></i></button> <% } %>
                            <form action="/pay-bill/<%= customer._id %>" method="POST" style="flex: 1;" onsubmit="openConfirmModal(event, this, 'pay')"><input type="hidden" name="cycleKey" value="<%= customer.cycleKey %>"><button type="submit" class="btn-done" style="margin-top: 0;"><i class="ri-money-rupee-circle-line"></i> Mark as Paid</button></form>
                        </div>
                    </div>
                <% }) %>
            </div>
            <div id="autoLoadSpinner" class="scroll-loader"><i class="ri-loader-4-line spin-loader"></i><br>Loading more...</div>
        </div>

        <div id="waTemplateModal" class="modal-overlay" style="display: none; z-index: 10500;"><div class="modal-card"><div class="modal-header"><h3><i class="ri-whatsapp-fill" style="color: #10b981;"></i> Quick Message</h3><button onclick="closeWaModal()" class="icon-btn"><i class="ri-close-line"></i></button></div><div id="waVerTemplates"><p style="font-size: 0.85rem; color: #64748b; margin-bottom: 10px;">Select a message for pending verification:</p><button class="wa-template-btn" data-text="Sir main Samshad from VI store Patel nagar se baat kar raha hu. Aapko msg aaya kya verification ke regarding?" onclick="sendWaTemplate(this)">💬 "Sir main Samshad from VI store..."</button><button class="wa-template-btn" data-text="WhatsApp pr koi msg aya kya aapko verification ka?" onclick="sendWaTemplate(this)">💬 "WhatsApp pr msg aya kya verification ka?"</button><button class="wa-template-btn" data-text="Koi call ya msg aaya kya verification ke regarding aapko?" onclick="sendWaTemplate(this)">💬 "Koi call ya msg aaya verification ke regarding?"</button><button class="wa-template-btn" data-text="Verification kr liya aapne apne number ka?" onclick="sendWaTemplate(this)">💬 "Verification kr liya aapne apne number ka?"</button></div><div id="waPddTemplates" style="display: none;"><p style="font-size: 0.85rem; color: #64748b; margin-bottom: 10px;">Select a message for pending bill payment:</p><button class="wa-template-btn" data-text="Sir main Samshad from VI store Patel nagar se baat kar raha hu. Remind kar raha tha ki aapka bill {{billDate}} ko ban gaya hai, use due date se pehle pay karna hai." onclick="sendWaTemplate(this)">💰 Samshad: "Aapka bill {{billDate}} ko ban gaya hai..."</button><button class="wa-template-btn" data-text="Aapka bill ban gaya hai. Kripya due date se pehle pay kar lijiye taaki service band na ho." onclick="sendWaTemplate(this)">💰 "Bill ban gaya hai, due date se pehle pay karlo..."</button><button class="wa-template-btn" data-text="Aapka bill aa gaya hai. Payment karke screenshot share kar dijiye please." onclick="sendWaTemplate(this)">📸 "Bill aa gaya hai, pay karke screenshot bhejo..."</button></div></div></div>

        <div id="remarksModal" class="modal-overlay" style="display: none;"><div class="modal-card"><div class="modal-header"><h3><i class="ri-sticky-note-fill" style="color: var(--primary);"></i> Remarks</h3><button onclick="closeRemarksModal()" class="icon-btn"><i class="ri-close-line"></i></button></div><div><strong id="remarksTitle" style="color: var(--primary); font-size: 1.1rem; display:block; margin-bottom:5px;"></strong><div id="remarksBody" class="remarks-content"></div></div><button onclick="closeRemarksModal()" class="btn-submit" style="background: var(--text-main); margin-top: 10px;">Close</button></div></div>
        <div id="customConfirmModal" class="modal-overlay" style="display: none; z-index: 10000;"><div class="modal-card" style="text-align: center; max-width: 340px; padding: 30px 20px;"><div id="confirmIcon" class="confirm-icon"></div><h3 id="confirmTitle" style="margin-bottom: 10px; font-size: 1.3rem;"></h3><p id="confirmMessage" style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5;"></p><div class="confirm-actions"><button type="button" class="btn-confirm-cancel" onclick="closeConfirmModal()">Cancel</button><button type="button" id="confirmYesBtn" class="btn-confirm-yes">Yes</button></div></div></div>
    </div> <div class="bottom-nav"><a href="/" class="nav-item"><i class="ri-home-4-line"></i><span>Home</span></a><a href="/all" class="nav-item"><i class="ri-list-check"></i><span>All</span></a><a href="/pdd" class="nav-item active"><i class="ri-file-paper-2-fill"></i><span>PDD</span></a><div class="nav-fab" onclick="openModal()"><i class="ri-add-line"></i></div><a href="/search" class="nav-item"><i class="ri-search-line"></i><span>Search</span></a><a href="/manage" class="nav-item"><i class="ri-edit-2-line"></i><span>Edit</span></a><a href="/analytics" class="nav-item"><i class="ri-pie-chart-line"></i><span>Analysis</span></a></div>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="/app.js"></script>
</body>
</html>