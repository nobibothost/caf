<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>
    
    <meta name="theme-color" content="#4f46e5">
    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/6595/6595982.png">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <style>
        body { margin: 0; font-family: 'Inter', sans-serif; background: #f8fafc; display: flex; justify-content: center; align-items: center; min-height: 100vh; background-image: radial-gradient(#e2e8f0 1px, transparent 1px); background-size: 20px 20px; }
        .login-card { background: white; padding: 40px 30px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); width: 100%; max-width: 360px; }
        .logo-icon { width: 55px; height: 55px; background: #4f46e5; color: white; border-radius: 14px; display: flex; justify-content: center; align-items: center; font-size: 1.8rem; margin: 0 auto 20px auto; box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3); }
        h2 { text-align: center; margin: 0 0 5px 0; color: #0f172a; font-size: 1.5rem; }
        p.sub { text-align: center; color: #64748b; font-size: 0.9rem; margin-bottom: 25px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 600; color: #64748b; margin-bottom: 8px; }
        .input-wrapper { position: relative; display: flex; align-items: center; width: 100%; }
        .input-wrapper i.left-icon { position: absolute; left: 15px; color: #64748b; font-size: 1.1rem; pointer-events: none; }
        /* Padded left for icon, padded right for eye toggle */
        .input-wrapper input { width: 100%; padding: 14px 45px; border: 1px solid #e2e8f0; border-radius: 12px; font-size: 0.95rem; outline: none; transition: all 0.2s; box-sizing: border-box; }
        .input-wrapper input:focus { border-color: #4f46e5; background: #f8fafc; }
        .toggle-pwd { position: absolute; right: 15px; cursor: pointer; color: #64748b; font-size: 1.1rem; padding: 5px; }
        .remember { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: #64748b; margin-bottom: 25px; cursor: pointer; }
        .btn-login { width: 100%; padding: 15px; background: #4f46e5; color: white; border: none; border-radius: 12px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: 0.2s; display: flex; justify-content: center; align-items: center; gap: 8px; }
        .btn-login:active { transform: scale(0.98); }
        .error-box { background: #fee2e2; color: #dc2626; padding: 12px; border-radius: 10px; font-size: 0.85rem; text-align: center; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-spinner { animation: basicSpin 1s linear infinite; display: inline-block; }
        @keyframes basicSpin { 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-icon"><i class="ri-shield-keyhole-fill"></i></div>
        <h2>Admin Login</h2>
        <p class="sub">Secure Access Portal</p>

        <% if (error) { %>
            <div class="error-box"><i class="ri-error-warning-line"></i> <%= error %></div>
        <% } %>

        <form action="/login" method="POST" id="loginForm">
            <div class="form-group">
                <label>Username</label>
                <div class="input-wrapper">
                    <i class="ri-user-line left-icon"></i>
                    <input type="text" name="username" required placeholder="Enter Username" autofocus>
                </div>
            </div>
            <div class="form-group">
                <label>Password</label>
                <div class="input-wrapper">
                    <i class="ri-lock-password-line left-icon"></i>
                    <input type="password" name="Vpassword" id="pwdInput" required placeholder="Enter Password">
                    <i class="ri-eye-off-line toggle-pwd" id="togglePwd" onclick="togglePassword()"></i>
                </div>
            </div>
            <label class="remember">
                <input type="checkbox" name="remember"> Remember me
            </label>
            <button type="submit" class="btn-login" id="loginBtn">Login & Send OTP</button>
        </form>
    </div>

    <script>
        // --- PWA SERVICE WORKER REGISTRATION ---
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(reg => {
                    console.log('SW Registered on Login', reg);
                }).catch(err => console.error('SW Reg Failed:', err));
            });
        }

        function togglePassword() {
            const input = document.getElementById('pwdInput');
            const icon = document.getElementById('togglePwd');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('ri-eye-off-line');
                icon.classList.add('ri-eye-line');
            } else {
                input.type = 'password';
                icon.classList.remove('ri-eye-line');
                icon.classList.add('ri-eye-off-line');
            }
        }

        document.getElementById('loginForm').addEventListener('submit', function() {
            const btn = document.getElementById('loginBtn');
            btn.innerHTML = '<i class="ri-loader-4-line btn-spinner"></i> Sending OTP...';
            btn.style.opacity = '0.7';
            btn.style.pointerEvents = 'none';
        });
    </script>
</body>
</html>