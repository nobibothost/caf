<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Records</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    
    <nav class="navbar">
        <div class="logo">
            <i class="ri-edit-box-line"></i> Manage<span class="highlight">Data</span>
        </div>
        <a href="/logout" class="logout-btn" onclick="return confirm('Securely Logout?');">
            <i class="ri-logout-box-r-line"></i>
        </a>
    </nav>

    <div class="container">
        
        <div class="section-title">
            <h2><i class="ri-settings-4-line"></i> <%= headerTitle %></h2>
            <p class="subtitle">Search, edit or delete records.</p>
        </div>

        <form action="/manage" method="GET" class="filter-form">
            <div class="filter-wrapper">
                <i class="ri-filter-3-line"></i>
                <select name="month" class="filter-select" onchange="this.form.submit()">
                    <option value="0" <%= monthOffset == 0 ? 'selected' : '' %>>This Month</option>
                    <option value="1" <%= monthOffset == 1 ? 'selected' : '' %>>Last Month</option>
                    <option value="2" <%= monthOffset == 2 ? 'selected' : '' %>>2 Months Ago</option>
                    <option value="all" <%= monthOffset === 'all' ? 'selected' : '' %>>Show All History</option>
                </select>
            </div>
        </form>

        <div class="search-box">
            <i class="ri-search-line"></i>
            <input type="text" id="searchInput" onkeyup="filterList()" placeholder="Search Name or Mobile...">
        </div>

        <div class="grid-layout" id="customerList">
            <% customers.forEach(customer => { %>
                <div class="card search-item">
                    <div class="card-top">
                        <% if (customer.category === 'Family') { %>
                            <span class="badge badge-Family">Family: <%= customer.subType %></span>
                        <% } else { %>
                            <span class="badge badge-<%= customer.category %>"><%= customer.category %></span>
                        <% } %>
                        <span class="date-tag">
                            <%= (customer.activationDate || customer.createdAt).toISOString().split('T')[0] %>
                        </span>
                    </div>

                    <% if (customer.category === 'Family') { %>
                        <div class="family-wrapper">
                            <div class="family-section primary-sec">
                                <span class="fs-label primary-label">Primary Connection</span>
                                <div class="fs-info">
                                    <h4><%= customer.linkedPrimaryName || 'Unknown' %></h4>
                                    <p><i class="ri-smartphone-line"></i> <%= customer.linkedPrimaryNumber %></p>
                                    <p style="font-size: 0.7rem; margin-top: 2px; color: #64748b;">
                                        <i class="ri-information-line"></i> <%= customer.linkedPrimaryStatus %>
                                    </p>
                                </div>
                                <div class="fs-actions">
                                    <a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i> WA</a>
                                    <a href="tel:<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i> Call</a>
                                </div>
                            </div>

                            <div class="family-section secondary-sec">
                                <span class="fs-label secondary-label">Secondary (This SIM)</span>
                                <div class="fs-info">
                                    <h4 class="customer-name"><%= customer.name %></h4>
                                    <p class="mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                                    <% if(customer.region && customer.region !== 'NA') { %>
                                        <p><i class="ri-map-pin-line"></i> <%= customer.region %></p>
                                    <% } %>
                                </div>
                                <div class="fs-actions">
                                    <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i> WA</a>
                                    <a href="tel:<%= customer.mobile %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i> Call</a>
                                </div>
                            </div>
                        </div>

                    <% } else { %>
                        <div class="card-body">
                            <h3 class="customer-name"><%= customer.name %></h3>
                            <p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                            <% if(customer.region && customer.region !== 'NA') { %>
                                <p class="meta-info"><i class="ri-map-pin-line"></i> <%= customer.region %></p>
                            <% } %>
                        </div>

                        <div class="card-actions" style="margin-bottom: 8px;">
                            <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp" style="flex: 1;">
                                <i class="ri-whatsapp-line"></i> WhatsApp
                            </a>
                            <a href="tel:<%= customer.mobile %>" class="btn-call" style="flex: 1;">
                                <i class="ri-phone-fill"></i> Call
                            </a>
                        </div>
                    <% } %>

                    <div class="card-actions">
                        <% if (customer.remarks && customer.remarks.trim() !== "") { %>
                            <button class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)">
                                <i class="ri-sticky-note-fill"></i>
                            </button>
                        <% } %>

                        <button class="btn-edit" 
                            data-id="<%= customer._id %>"
                            data-name="<%= customer.name %>"
                            data-mobile="<%= customer.mobile %>"
                            data-category="<%= customer.category %>"
                            data-region="<%= customer.region || 'NA' %>"
                            data-date="<%= (customer.activationDate || customer.createdAt).toISOString().split('T')[0] %>"
                            data-remarks="<%= customer.remarks || '' %>"
                            onclick="openEditModal(this)">
                            <i class="ri-pencil-line"></i> Edit / Delete
                        </button>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div id="editModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <div class="modal-header">
                <h3>Edit Record</h3>
                <button onclick="closeEditModal()" class="icon-btn"><i class="ri-close-line"></i></button>
            </div>
            
            <form id="editForm" method="POST">
                <div class="input-group">
                    <label>Activation Date</label>
                    <div class="input-wrapper">
                        <i class="ri-calendar-line icon-left"></i>
                        <input type="date" name="activationDate" id="editDate" required>
                    </div>
                </div>

                <div class="input-group">
                    <label>Type</label>
                    <div class="input-wrapper">
                        <i class="ri-list-check icon-left"></i>
                        <select name="category" id="editCategory" onchange="toggleEditRegion()" required>
                            <option value="NC">NC</option>
                            <option value="P2P">P2P</option>
                            <option value="MNP">MNP</option>
                            <option value="Family">Family</option>
                        </select>
                    </div>
                </div>

                <div class="input-group" id="edit-region-group" style="display: none;">
                    <label>Region</label>
                    <div class="input-wrapper">
                        <i class="ri-map-pin-user-line icon-left"></i>
                        <select name="region" id="editRegion">
                            <option value="NA">Select</option>
                            <option value="Delhi">Delhi</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <div class="input-group">
                    <label>Name</label>
                    <div class="input-wrapper">
                        <i class="ri-user-smile-line icon-left"></i>
                        <input type="text" name="name" id="editName" required>
                    </div>
                </div>

                <div class="input-group">
                    <label>Mobile</label>
                    <div class="input-wrapper">
                        <i class="ri-smartphone-line icon-left"></i>
                        <input type="tel" name="mobile" id="editMobile" pattern="[0-9]{10}" required>
                    </div>
                </div>

                <div class="input-group">
                    <label>Remarks</label>
                    <div class="input-wrapper">
                        <i class="ri-sticky-note-line icon-left"></i>
                        <input type="text" name="remarks" id="editRemarks">
                    </div>
                </div>

                <button type="submit" class="btn-submit">Update Record</button>
            </form>

            <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

            <form id="deleteForm" method="POST" onsubmit="return confirm('Are you sure you want to delete this record permanently?');">
                <button type="submit" class="btn-delete">
                    <i class="ri-delete-bin-line"></i> Delete Record
                </button>
            </form>
        </div>
    </div>

    <div id="remarksModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <div class="modal-header">
                <h3><i class="ri-sticky-note-fill" style="color: var(--primary);"></i> Remarks</h3>
                <button onclick="closeRemarksModal()" class="icon-btn"><i class="ri-close-line"></i></button>
            </div>
            <div>
                <strong id="remarksTitle" style="color: var(--primary); font-size: 1.1rem; display:block; margin-bottom:5px;"></strong>
                <div id="remarksBody" class="remarks-content"></div>
            </div>
            <button onclick="closeRemarksModal()" class="btn-submit" style="background: var(--text-main); margin-top: 10px;">Close</button>
        </div>
    </div>

    <div class="bottom-nav">
        <a href="/" class="nav-item">
            <i class="ri-home-4-line"></i>
            <span>Home</span>
        </a>
        <a href="/all" class="nav-item">
            <i class="ri-list-check"></i>
            <span>All</span>
        </a>
        <div class="nav-fab" onclick="window.location.href='/'">
            <i class="ri-add-line"></i>
        </div>
        <a href="/manage" class="nav-item active">
            <i class="ri-edit-2-fill"></i>
            <span>Edit</span>
        </a>
        <a href="/analytics" class="nav-item">
            <i class="ri-pie-chart-line"></i>
            <span>Analysis</span>
        </a>
    </div>

    <script>
        function filterList() {
            let input = document.getElementById('searchInput').value.toLowerCase();
            let items = document.getElementsByClassName('search-item');

            for (let i = 0; i < items.length; i++) {
                let name = items[i].getElementsByClassName('customer-name')[0].innerText.toLowerCase();
                let mobile = items[i].getElementsByClassName('mobile-txt')[0].innerText.toLowerCase();
                if (name.includes(input) || mobile.includes(input)) {
                    items[i].style.display = "";
                } else {
                    items[i].style.display = "none";
                }
            }
        }

        const modal = document.getElementById("editModal");
        const remarksModal = document.getElementById("remarksModal");
        const regionGroup = document.getElementById('edit-region-group');

        function openEditModal(btn) { 
            document.getElementById('editForm').action = "/edit/" + btn.getAttribute('data-id'); 
            document.getElementById('deleteForm').action = "/delete/" + btn.getAttribute('data-id'); 
            
            document.getElementById('editName').value = btn.getAttribute('data-name'); 
            document.getElementById('editMobile').value = btn.getAttribute('data-mobile'); 
            document.getElementById('editDate').value = btn.getAttribute('data-date'); 
            document.getElementById('editCategory').value = btn.getAttribute('data-category'); 
            document.getElementById('editRegion').value = btn.getAttribute('data-region'); 
            document.getElementById('editRemarks').value = btn.getAttribute('data-remarks'); 

            toggleEditRegion(); 
            
            // Force Display
            modal.style.display = 'flex';
            setTimeout(() => { modal.classList.add('active'); }, 10);
        }

        function closeEditModal() { 
            modal.classList.remove('active'); 
            setTimeout(() => { modal.style.display = 'none'; }, 300);
        }
        
        function openRemarksModal(btn) { 
            document.getElementById('remarksTitle').innerText = btn.getAttribute('data-name'); 
            document.getElementById('remarksBody').innerText = btn.getAttribute('data-remarks'); 
            
            remarksModal.style.display = 'flex';
            setTimeout(() => { remarksModal.classList.add('active'); }, 10);
        }

        function closeRemarksModal() { 
            remarksModal.classList.remove('active'); 
            setTimeout(() => { remarksModal.style.display = 'none'; }, 300);
        }

        function toggleEditRegion() {
            const cat = document.getElementById('editCategory').value;
            if (cat === 'MNP' || cat === 'Family') {
                regionGroup.style.display = 'block';
            } else {
                regionGroup.style.display = 'none';
            }
        }

        window.onclick = function(event) { 
            if (event.target == modal) closeEditModal(); 
            if (event.target == remarksModal) closeRemarksModal(); 
        }
    </script>
</body>
</html>
