<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Records</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .form-section { display: none; }
        .form-section.active { display: block; animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
        .divider { height: 1px; background: #e2e8f0; margin: 20px 0; position: relative; }
        .divider span { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 0 10px; color: #64748b; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
        .section-label { font-size: 0.95rem; font-weight: 700; color: var(--primary); margin-bottom: 12px; display: block; }
        .flatpickr-input { background-color: #f8fafc !important; }
    </style>
</head>
<body>
    <nav class="navbar"><div class="logo"><i class="ri-edit-box-line"></i> Manage<span class="highlight">Data</span></div><a href="#" class="logout-btn" onclick="openConfirmModal(event, '/logout', 'logout')"><i class="ri-logout-box-r-line"></i></a></nav>

    <div class="container">
        <div class="section-title"><h2><i class="ri-settings-4-line"></i> <%= headerTitle %></h2><p class="subtitle">Search, edit or delete records.</p></div>
        <form action="/manage" method="GET" class="filter-form"><div class="filter-wrapper"><i class="ri-filter-3-line"></i><select name="month" class="filter-select" onchange="this.form.submit()"><option value="0" <%= monthOffset == 0 ? 'selected' : '' %>>This Month</option><option value="1" <%= monthOffset == 1 ? 'selected' : '' %>>Last Month</option><option value="2" <%= monthOffset == 2 ? 'selected' : '' %>>2 Months Ago</option><option value="all" <%= monthOffset === 'all' ? 'selected' : '' %>>Show All History</option></select></div></form>
        <div class="search-box"><i class="ri-search-line"></i><input type="text" id="searchInput" onkeyup="filterList()" placeholder="Quick filter on this page..."></div>

        <div class="grid-layout" id="customerList">
            <% customers.forEach(customer => { %>
                <div class="card search-item">
                    <div class="card-top">
                        <div style="display: flex; gap: 5px;">
                            <% if (customer.category === 'Family') { %> <span class="badge badge-Family">Family</span> <% } else { %> <span class="badge badge-<%= customer.category %>"><%= customer.category %></span> <% } %>
                        </div>
                        <span class="date-tag"><%= new Date(customer.activationDate || customer.createdAt).toLocaleDateString('en-GB') %></span>
                    </div>

                    <% if (customer.category === 'Family') { %>
                        <div class="family-wrapper">
                            <div class="family-section primary-sec">
                                <span class="fs-label primary-label">Primary Connection
                                    <% if (customer.primaryDoc) { %>
                                        <span class="badge badge-<%= customer.primaryDoc.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.primaryDoc.subType %></span>
                                    <% } else { %>
                                        <span class="badge" style="background:#e2e8f0; color:#475569; font-size: 0.6rem; padding: 2px 5px;">Existing</span>
                                    <% } %>
                                </span>
                                <div class="fs-info"><h4><%= customer.linkedPrimaryName || 'Unknown' %></h4><p><%= customer.linkedPrimaryNumber %></p></div>
                                <div class="fs-actions"><a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a><a href="tel:<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a></div>
                            </div>
                            <div class="family-section secondary-sec">
                                <span class="fs-label secondary-label">Secondary (This SIM)
                                    <span class="badge badge-<%= customer.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.subType %></span>
                                </span>
                                <div class="fs-info"><h4 class="customer-name"><%= customer.name %></h4><p class="mobile-txt"><%= customer.mobile %></p></div>
                                <div class="fs-actions"><a href="whatsapp://send?phone=91<%= customer.mobile %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a><a href="tel:<%= customer.mobile %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a></div>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="card-body"><h3 class="customer-name"><%= customer.name %></h3><p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p></div>
                        <div class="card-actions" style="margin-bottom: 8px;"><a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp" style="flex: 1;"><i class="ri-whatsapp-line"></i> WhatsApp</a><a href="tel:<%= customer.mobile %>" class="btn-call" style="flex: 1;"><i class="ri-phone-fill"></i> Call</a></div>
                    <% } %>

                    <div class="card-actions">
                        <% if (customer.remarks && customer.remarks.trim() !== "") { %> <button class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)"><i class="ri-sticky-note-fill"></i></button> <% } %>
                        
                        <button class="btn-edit" 
                            data-id="<%= customer._id %>" 
                            data-category="<%= customer.category %>" 
                            data-date="<%= (customer.activationDate ? new Date(customer.activationDate) : new Date(customer.createdAt)).toISOString().split('T')[0] %>" 
                            data-remarks="<%= customer.remarks || '' %>" 
                            data-name="<%= customer.name %>" 
                            data-mobile="<%= customer.mobile %>" 
                            data-subtype="<%= customer.subType %>" 
                            data-p-name="<%= customer.linkedPrimaryName || '' %>" 
                            data-p-mobile="<%= customer.linkedPrimaryNumber || '' %>" 
                            data-p-status="<%= customer.primaryDoc ? customer.primaryDoc.subType : (customer.linkedPrimaryStatus || '') %>"
                            data-billdate="<%= customer.billDate || '' %>" 
                            onclick="openEditModal(this)">
                            <i class="ri-pencil-line"></i> Edit / Manage Full Info
                        </button>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div id="editModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <div class="modal-header"><h3>Edit Record</h3><button onclick="closeEditModal()" class="icon-btn"><i class="ri-close-line"></i></button></div>
            <form id="editForm" method="POST">
                <div class="input-group"><label>Activation Date</label><div class="input-wrapper"><i class="ri-calendar-line icon-left"></i><input type="text" name="activationDate" id="editDate" required placeholder="DD/MM/YYYY"></div></div>
                <div class="input-group"><label>Type</label><div class="input-wrapper"><i class="ri-list-check icon-left"></i><select name="category" id="editCategory" onchange="handleEditCategoryChange()" required><option value="NC">NC</option><option value="P2P">P2P</option><option value="MNP">MNP</option><option value="NMNP">NMNP</option><option value="Family">Family</option></select></div></div>
                <div id="edit-normal-form" class="form-section"><div class="input-group"><label>Name</label><div class="input-wrapper"><i class="ri-user-smile-line icon-left"></i><input type="text" name="n_name" id="editNName"></div></div><div class="input-group"><label>Mobile</label><div class="input-wrapper"><i class="ri-smartphone-line icon-left"></i><input type="tel" name="n_mobile" id="editNMobile" pattern="[0-9]{10}"></div></div></div>
                <div id="edit-family-form" class="form-section">
                    <span class="section-label">Primary Connection</span>
                    <div class="input-group"><label>Primary Type</label><div class="input-wrapper"><i class="ri-shield-user-line icon-left"></i><select name="p_type" id="editPType"><option value="Existing">Existing (Active)</option><option value="NC">New Entry (NC)</option><option value="P2P">New Entry (P2P)</option><option value="MNP">New MNP</option><option value="NMNP">New NMNP</option></select></div></div>
                    <div class="input-group"><div class="input-wrapper"><i class="ri-user-star-line icon-left"></i><input type="text" name="p_name" id="editPName" placeholder="Primary Name"></div></div><div class="input-group"><div class="input-wrapper"><i class="ri-smartphone-line icon-left"></i><input type="tel" name="p_mobile" id="editPMobile" placeholder="Primary Mobile" pattern="[0-9]{10}"></div></div>
                    <div class="divider"><span>AND</span></div>
                    <span class="section-label">Secondary Connection (This SIM)</span>
                    <div class="input-group"><label>Secondary Type</label><div class="input-wrapper"><i class="ri-sim-card-line icon-left"></i><select name="s_type" id="editSType"><option value="NC" selected>NC</option><option value="P2P">P2P</option><option value="MNP">MNP</option><option value="NMNP">NMNP</option></select></div></div>
                    <div class="input-group"><div class="input-wrapper"><i class="ri-user-smile-line icon-left"></i><input type="text" name="s_name" id="editSName" placeholder="Secondary Name"></div></div><div class="input-group"><div class="input-wrapper"><i class="ri-smartphone-line icon-left"></i><input type="tel" name="s_mobile" id="editSMobile" placeholder="Secondary Mobile" pattern="[0-9]{10}"></div></div>
                </div>
                <div class="input-group" style="margin-top: 15px;">
                    <label>Bill Date (Optional)</label>
                    <div class="input-wrapper">
                        <i class="ri-calendar-todo-line icon-left"></i>
                        <select name="billDate" id="editBillDate">
                            <option value="">No Bill / Prepaid</option>
                            <option value="11">11th</option>
                            <option value="15">15th</option>
                            <option value="24">24th</option>
                            <option value="27">27th</option>
                        </select>
                    </div>
                </div>
                <div class="input-group" style="margin-top: 15px;"><label>Remarks</label><div class="input-wrapper"><i class="ri-sticky-note-line icon-left"></i><input type="text" name="remarks" id="editRemarks"></div></div>
                <button type="submit" class="btn-submit">Update Record</button>
            </form>
            <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">
            <form id="deleteForm" method="POST" onsubmit="openConfirmModal(event, this, 'delete')">
                <button type="submit" class="btn-delete"><i class="ri-delete-bin-line"></i> Delete Full Entry</button>
            </form>
        </div>
    </div>

    <div id="customConfirmModal" class="modal-overlay" style="display: none; z-index: 10000;">
        <div class="modal-card" style="text-align: center; max-width: 340px; padding: 30px 20px;">
            <div id="confirmIcon" class="confirm-icon"></div>
            <h3 id="confirmTitle" style="margin-bottom: 10px; font-size: 1.3rem;"></h3>
            <p id="confirmMessage" style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5;"></p>
            <div class="confirm-actions">
                <button type="button" class="btn-confirm-cancel" onclick="closeConfirmModal()">Cancel</button>
                <button type="button" id="confirmYesBtn" class="btn-confirm-yes">Yes</button>
            </div>
        </div>
    </div>

    <div class="bottom-nav">
        <a href="/" class="nav-item"><i class="ri-home-4-line"></i><span>Home</span></a>
        <a href="/all" class="nav-item"><i class="ri-list-check"></i><span>All</span></a>
        <a href="/pdd" class="nav-item"><i class="ri-file-paper-2-line"></i><span>PDD</span></a>
        <div class="nav-fab" onclick="window.location.href='/'"><i class="ri-add-line"></i></div>
        <a href="/search" class="nav-item"><i class="ri-search-line"></i><span>Search</span></a>
        <a href="/manage" class="nav-item active"><i class="ri-edit-2-fill"></i><span>Edit</span></a>
        <a href="/analytics" class="nav-item"><i class="ri-pie-chart-line"></i><span>Analysis</span></a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        function filterList() { let input = document.getElementById('searchInput').value.toLowerCase(); let items = document.getElementsByClassName('search-item'); for (let i = 0; i < items.length; i++) { let text = items[i].innerText.toLowerCase(); if (text.includes(input)) items[i].style.display = ""; else items[i].style.display = "none"; } }
        
        const modal = document.getElementById("editModal");
        const fpEdit = flatpickr("#editDate", { dateFormat: "Y-m-d", altInput: true, altFormat: "d/m/Y", allowInput: true, disableMobile: true });
        
        function openEditModal(btn) { 
            document.getElementById('editForm').action = "/edit/" + btn.getAttribute('data-id');
            document.getElementById('deleteForm').action = "/delete/" + btn.getAttribute('data-id'); 
            
            const cat = btn.getAttribute('data-category'); 
            document.getElementById('editCategory').value = cat;
            fpEdit.setDate(btn.getAttribute('data-date'));
            document.getElementById('editRemarks').value = btn.getAttribute('data-remarks');
            document.getElementById('editBillDate').value = btn.getAttribute('data-billdate') || '';

            if (cat === 'Family') { 
                const pStatus = btn.getAttribute('data-p-status');
                let pType = 'Existing';
                if (pStatus.includes('NMNP')) pType = 'NMNP'; else if (pStatus.includes('MNP')) pType = 'MNP';
                else if (pStatus.includes('NC')) pType = 'NC'; else if (pStatus.includes('P2P')) pType = 'P2P'; 
                document.getElementById('editPType').value = pType; document.getElementById('editPName').value = btn.getAttribute('data-p-name');
                document.getElementById('editPMobile').value = btn.getAttribute('data-p-mobile'); document.getElementById('editSType').value = btn.getAttribute('data-subtype'); document.getElementById('editSName').value = btn.getAttribute('data-name'); document.getElementById('editSMobile').value = btn.getAttribute('data-mobile');
            } else { document.getElementById('editNName').value = btn.getAttribute('data-name');
                document.getElementById('editNMobile').value = btn.getAttribute('data-mobile'); document.getElementById('editSType').value = cat; } handleEditCategoryChange(); modal.style.display = 'flex'; setTimeout(() => { modal.classList.add('active'); }, 10);
        }
        function closeEditModal() { modal.classList.remove('active'); setTimeout(() => { modal.style.display = 'none'; }, 300); }
        function handleEditCategoryChange() { const cat = document.getElementById('editCategory').value; const nForm = document.getElementById('edit-normal-form');
            const fForm = document.getElementById('edit-family-form'); nForm.classList.remove('active'); fForm.classList.remove('active'); if (cat === 'Family') { fForm.classList.add('active'); document.getElementById('editNName').required = false; document.getElementById('editNMobile').required = false;
            } else { nForm.classList.add('active'); document.getElementById('editNName').required = true; document.getElementById('editNMobile').required = true;
            } }

        // --- CUSTOM CONFIRM MODAL LOGIC ---
        let formToSubmit = null;
        function openConfirmModal(event, element, actionType) {
            event.preventDefault();
            formToSubmit = element;
            
            const titleEl = document.getElementById('confirmTitle');
            const msgEl = document.getElementById('confirmMessage');
            const iconEl = document.getElementById('confirmIcon');
            const yesBtn = document.getElementById('confirmYesBtn');

            yesBtn.className = 'btn-confirm-yes';
            
            if (actionType === 'delete') {
                titleEl.innerText = "Delete Record?";
                msgEl.innerText = "This action is permanent. Both primary and secondary info will be removed.";
                iconEl.innerHTML = '<i class="ri-delete-bin-line" style="color: #ef4444;"></i>';
                yesBtn.classList.add('btn-confirm-danger');
                yesBtn.innerText = "Yes, Delete";
            } else if (actionType === 'logout') {
                titleEl.innerText = "Secure Logout?";
                msgEl.innerText = "Are you sure you want to end your session?";
                iconEl.innerHTML = '<i class="ri-logout-circle-line" style="color: #ef4444;"></i>';
                yesBtn.classList.add('btn-confirm-danger');
                yesBtn.innerText = "Yes, Logout";
            }

            document.getElementById('customConfirmModal').style.display = 'flex';
            setTimeout(() => document.getElementById('customConfirmModal').classList.add('active'), 10);
        }

        function closeConfirmModal() {
            document.getElementById('customConfirmModal').classList.remove('active');
            setTimeout(() => document.getElementById('customConfirmModal').style.display = 'none', 300);
            formToSubmit = null;
        }

        document.getElementById('confirmYesBtn').addEventListener('click', function() {
            if (formToSubmit) {
                if (typeof formToSubmit === 'string') {
                    window.location.href = formToSubmit;
                } else {
                    let returnInput = formToSubmit.querySelector('input[name="returnUrl"]');
                    if (!returnInput) {
                        returnInput = document.createElement('input'); returnInput.type = 'hidden'; returnInput.name = 'returnUrl'; formToSubmit.appendChild(returnInput);
                    }
                    returnInput.value = window.location.pathname + window.location.search;
                    sessionStorage.setItem('scrollPos', window.scrollY);
                    sessionStorage.setItem('scrollPath', window.location.pathname + window.location.search);
                    formToSubmit.submit();
                }
            }
        });

        window.onclick = function(event) { if (event.target == modal) closeEditModal(); if(event.target == document.getElementById('customConfirmModal')) closeConfirmModal(); }

        // --- SCROLL RESTORE FOR EDIT FORM ---
        document.querySelectorAll('form:not([onsubmit*="openConfirmModal"])').forEach(form => {
            form.addEventListener('submit', function() {
                let returnInput = this.querySelector('input[name="returnUrl"]');
                if (!returnInput) { returnInput = document.createElement('input'); returnInput.type = 'hidden'; returnInput.name = 'returnUrl'; this.appendChild(returnInput); }
                returnInput.value = window.location.pathname + window.location.search;
                sessionStorage.setItem('scrollPos', window.scrollY);
                sessionStorage.setItem('scrollPath', window.location.pathname + window.location.search);
            });
        });

        window.addEventListener('DOMContentLoaded', () => {
            const scrollPath = sessionStorage.getItem('scrollPath');
            const currentPath = window.location.pathname + window.location.search;
            if (scrollPath === currentPath) {
                const scrollPos = sessionStorage.getItem('scrollPos');
                if (scrollPos) setTimeout(() => window.scrollTo(0, parseInt(scrollPos)), 50);
            }
            sessionStorage.removeItem('scrollPos'); sessionStorage.removeItem('scrollPath');
        });
    </script>
</body>
</html>