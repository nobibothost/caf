<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Records</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    
    <nav class="navbar">
        <div class="logo">
            <i class="ri-folder-history-line"></i> All<span class="highlight">Records</span>
        </div>
        <a href="/logout" class="logout-btn" onclick="return confirm('Securely Logout?');">
            <i class="ri-logout-box-r-line"></i>
        </a>
    </nav>

    <div class="container">
        
        <div class="section-title">
            <h2><i class="ri-database-2-line"></i> <%= headerTitle %></h2>
            <p class="subtitle">Activation records history.</p>
        </div>

        <form action="/all" method="GET" class="filter-form">
            <div class="filter-wrapper">
                <i class="ri-filter-3-line"></i>
                <select name="month" class="filter-select" onchange="this.form.submit()">
                    <option value="0" <%= monthOffset == 0 ? 'selected' : '' %>>This Month</option>
                    <option value="1" <%= monthOffset == 1 ? 'selected' : '' %>>Last Month</option>
                    <option value="2" <%= monthOffset == 2 ? 'selected' : '' %>>2 Months Ago</option>
                    <option value="all" <%= monthOffset === 'all' ? 'selected' : '' %>>Show All History</option>
                </select>
            </div>
        </form>

        <div class="grid-layout">
            <% if (customers.length === 0) { %>
                <div class="empty-state">
                    <div class="icon-box"><i class="ri-file-search-line"></i></div>
                    <h3>No Records</h3>
                    <p>No data found for this period.</p>
                </div>
            <% } else { %>
                <% customers.forEach(customer => { %>
                    <div class="card" style="<%= customer.status === 'completed' ? 'opacity: 0.6; background: #f8fafc;' : '' %>">
                        
                        <div class="card-top">
                            <div style="display: flex; gap: 5px;">
                                <% if (customer.category === 'Family') { %> 
                                    <span class="badge badge-Family">Family</span> 
                                    <span class="badge badge-<%= customer.subType %>"><%= customer.subType %></span>
                                    <% if (customer.familyRole === 'Primary') { %> 
                                        <span class="badge" style="background:#e0e7ff; color:#3730a3;">Primary</span> 
                                    <% } %>
                                <% } else { %> 
                                    <span class="badge badge-<%= customer.category %>"><%= customer.category %></span> 
                                <% } %>
                            </div>

                            <% if (customer.status === 'completed') { %>
                                <span class="badge" style="background: #dcfce7; color: #166534;">
                                    <i class="ri-check-double-line"></i> Done
                                </span>
                            <% } else { %>
                                <span class="badge" style="background: #fef9c3; color: #854d0e;">
                                    <i class="ri-loader-4-line"></i> Pending
                                </span>
                            <% } %>
                        </div>

                        <% if (customer.category === 'Family' && customer.familyRole === 'Secondary') { %>
                            <div class="family-wrapper">
                                <div class="family-section primary-sec">
                                    <span class="fs-label primary-label">Primary Connection</span>
                                    <div class="fs-info">
                                        <h4><%= customer.linkedPrimaryName || 'Unknown' %></h4>
                                        <p><i class="ri-smartphone-line"></i> <%= customer.linkedPrimaryNumber %></p>
                                        <p style="font-size: 0.7rem; margin-top: 2px; color: #64748b;">
                                            <i class="ri-information-line"></i> <%= customer.linkedPrimaryStatus %>
                                        </p>
                                    </div>
                                    <div class="fs-actions">
                                        <a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i> WA</a>
                                        <a href="tel:<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i> Call</a>
                                    </div>
                                </div>

                                <div class="family-section secondary-sec">
                                    <span class="fs-label secondary-label">Secondary (This SIM)</span>
                                    <div class="fs-info">
                                        <h4><%= customer.name %></h4>
                                        <p><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                                        
                                        <p style="font-size: 0.7rem; margin-top: 2px; color: #64748b;">
                                            <i class="ri-information-line"></i> 
                                            Type: <%= customer.subType %> 
                                            <% if(customer.subType === 'MNP' && customer.region && customer.region !== 'NA') { %>
                                                (<%= customer.region %>)
                                            <% } %>
                                        </p>
                                    </div>
                                    <div class="fs-actions">
                                        <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i> WA</a>
                                        <a href="tel:<%= customer.mobile %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i> Call</a>
                                    </div>
                                </div>
                            </div>

                        <% } else { %>
                            <div class="card-body">
                                <h3 class="customer-name"><%= customer.name %></h3>
                                <p class="meta-info" style="color: var(--text-main); font-weight: 500;">
                                    <i class="ri-smartphone-line"></i> <%= customer.mobile %>
                                </p>
                                <p class="meta-info">
                                    <i class="ri-calendar-check-line"></i> 
                                    Activation: <%= (customer.activationDate || customer.createdAt).toLocaleDateString('en-GB') %>
                                </p>
                                <% if(customer.region && customer.region !== 'NA') { %>
                                    <p class="meta-info"><i class="ri-map-pin-line"></i> <%= customer.region %></p>
                                <% } %>
                            </div>
                            <div class="card-actions">
                                <a href="tel:<%= customer.mobile %>" class="btn-call"><i class="ri-phone-fill"></i> Call</a>
                                <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp"><i class="ri-whatsapp-line"></i> WhatsApp</a>
                            </div>
                        <% } %>

                        <% if (customer.remarks && customer.remarks.trim() !== "") { %>
                            <div class="card-actions" style="margin-top: 10px; border-top: 1px solid #eee; padding-top: 10px;">
                                <button class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)" style="width: 100%;">
                                    <i class="ri-sticky-note-fill"></i> View Note
                                </button>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <div id="remarksModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <div class="modal-header">
                <h3><i class="ri-sticky-note-fill" style="color: var(--primary);"></i> Remarks</h3>
                <button onclick="closeRemarksModal()" class="icon-btn"><i class="ri-close-line"></i></button>
            </div>
            <div>
                <strong id="remarksTitle" style="color: var(--primary); font-size: 1.1rem; display:block; margin-bottom:5px;"></strong>
                <div id="remarksBody" class="remarks-content"></div>
            </div>
            <button onclick="closeRemarksModal()" class="btn-submit" style="background: var(--text-main); margin-top: 10px;">Close</button>
        </div>
    </div>

    <div class="bottom-nav">
        <a href="/" class="nav-item">
            <i class="ri-home-4-line"></i>
            <span>Home</span>
        </a>
        <a href="/all" class="nav-item active">
            <i class="ri-list-check-2"></i>
            <span>All</span>
        </a>
        <div class="nav-fab" onclick="window.location.href='/'">
            <i class="ri-add-line"></i>
        </div>
        <a href="/manage" class="nav-item">
            <i class="ri-edit-2-line"></i>
            <span>Edit</span>
        </a>
        <a href="/analytics" class="nav-item">
            <i class="ri-pie-chart-line"></i>
            <span>Analysis</span>
        </a>
    </div>

    <script>
        const remarksModal = document.getElementById("remarksModal");

        function openRemarksModal(btn) {
            document.getElementById('remarksTitle').innerText = btn.getAttribute('data-name');
            document.getElementById('remarksBody').innerText = btn.getAttribute('data-remarks');
            
            remarksModal.style.display = 'flex';
            setTimeout(() => { remarksModal.classList.add('active'); }, 10);
        }

        function closeRemarksModal() {
            remarksModal.classList.remove('active'); 
            setTimeout(() => { remarksModal.style.display = 'none'; }, 300);
        }

        window.onclick = function(event) { 
            if (event.target == remarksModal) closeRemarksModal(); 
        }
    </script>
</body>
</html>
