<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>History</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .form-section { display: none; }
        .form-section.active { display: block; animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
        .divider { height: 1px; background: #e2e8f0; margin: 20px 0; position: relative; }
        .divider span { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 0 10px; color: #64748b; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
        .section-label { font-size: 0.95rem; font-weight: 700; color: var(--primary); margin-bottom: 12px; display: block; }
        .flatpickr-input { background-color: #f8fafc !important; }
    </style>
</head>
<body>
    
    <nav class="navbar">
        <div class="logo">
            <i class="ri-history-line"></i> History<span class="highlight">Log</span>
        </div>
        <a href="/logout" class="logout-btn" onclick="return confirm('Securely Logout?');">
            <i class="ri-logout-box-r-line"></i>
        </a>
    </nav>

    <div class="container">
        
        <div class="section-title">
            <h2><i class="ri-file-list-3-line"></i> <%= headerTitle %></h2>
            <p class="subtitle">Complete verification history.</p>
        </div>

        <form action="/all" method="GET" class="filter-form">
            <div class="filter-wrapper">
                <i class="ri-filter-3-line"></i>
                <select name="month" class="filter-select" onchange="this.form.submit()">
                    <option value="0" <%= monthOffset == 0 ? 'selected' : '' %>>This Month</option>
                    <option value="1" <%= monthOffset == 1 ? 'selected' : '' %>>Last Month</option>
                    <option value="2" <%= monthOffset == 2 ? 'selected' : '' %>>2 Months Ago</option>
                    <option value="all" <%= monthOffset === 'all' ? 'selected' : '' %>>Show All History</option>
                </select>
            </div>
        </form>

        <div class="grid-layout">
            <% customers.forEach(customer => { %>
                <div class="card" style="<%= customer.status === 'completed' ? 'opacity: 0.8;' : '' %>">
                    <div class="card-top">
                        <div style="display: flex; gap: 5px;">
                            <% if (customer.category === 'Family') { %>
                                <span class="badge badge-Family">Family</span>
                                <span class="badge badge-<%= customer.subType %>"><%= customer.subType %></span>
                            <% } else { %>
                                <span class="badge badge-<%= customer.category %>"><%= customer.category %></span>
                            <% } %>
                        </div>
                        <span class="date-tag"><%= (customer.activationDate || customer.createdAt).toLocaleDateString('en-GB') %></span>
                    </div>

                    <% if (customer.category === 'Family') { %>
                        <div class="family-wrapper">
                            <div class="family-section primary-sec">
                                <span class="fs-label primary-label">Primary Connection</span>
                                <div class="fs-info">
                                    <h4><%= customer.linkedPrimaryName || 'Unknown' %></h4>
                                    <p><%= customer.linkedPrimaryNumber %></p>
                                    <p style="font-size:0.7rem; color:#64748b;"><%= customer.linkedPrimaryStatus %></p>
                                </div>
                                <div class="fs-actions">
                                    <a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a>
                                    <a href="tel:<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a>
                                </div>
                            </div>
                            <div class="family-section secondary-sec">
                                <span class="fs-label secondary-label">Secondary (This SIM)</span>
                                <div class="fs-info">
                                    <h4 class="customer-name"><%= customer.name %></h4>
                                    <p class="mobile-txt"><%= customer.mobile %></p>
                                    <p style="font-size:0.7rem; color:#64748b;">Type: <%= customer.subType %></p>
                                </div>
                                <div class="fs-actions">
                                    <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a>
                                    <a href="tel:<%= customer.mobile %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="card-body">
                            <h3 class="customer-name"><%= customer.name %></h3>
                            <p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                        </div>
                        <div class="card-actions" style="margin-bottom: 8px;">
                            <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp" style="flex: 1;">
                                <i class="ri-whatsapp-line"></i> WhatsApp
                            </a>
                            <a href="tel:<%= customer.mobile %>" class="btn-call" style="flex: 1;">
                                <i class="ri-phone-fill"></i> Call
                            </a>
                        </div>
                    <% } %>

                    <div class="card-actions" style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <% if (customer.remarks && customer.remarks.trim() !== "") { %>
                                <button class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)">
                                    <i class="ri-sticky-note-fill"></i> Note
                                </button>
                            <% } %>
                        </div>

                        <span style="font-size: 0.8rem; font-weight: 600; color: <%= customer.status === 'completed' ? '#10b981' : '#f59e0b' %>;">
                            <%= customer.status === 'completed' ? '✅ COMPLETED' : '⏳ PENDING' %>
                        </span>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div id="addModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <div class="modal-header">
                <h3>New Verification</h3>
                <button onclick="closeModal()" class="icon-btn"><i class="ri-close-line"></i></button>
            </div>
            <form action="/add" method="POST" id="addForm">
                <div class="input-group">
                    <label>Activation Date</label>
                    <div class="input-wrapper">
                        <i class="ri-calendar-line icon-left"></i>
                        <input type="text" name="customDate" id="customDate" required placeholder="DD/MM/YYYY">
                    </div>
                </div>

                <div class="input-group">
                    <label>Category</label>
                    <div class="input-wrapper">
                        <i class="ri-list-check icon-left"></i>
                        <select name="category" id="category" onchange="handleCategoryChange()" required>
                            <option value="" disabled selected>Select Category</option>
                            <option value="NC">NC</option>
                            <option value="P2P">P2P</option>
                            <option value="MNP">MNP - Metro</option>
                            <option value="NMNP">NMNP - Non Metro</option>
                            <option value="Family">Family</option>
                        </select>
                    </div>
                </div>

                <div id="normal-form" class="form-section">
                    <div class="input-group"><label>Name</label><div class="input-wrapper"><i class="ri-user-smile-line icon-left"></i><input type="text" name="n_name" id="n_name"></div></div>
                    <div class="input-group"><label>Mobile</label><div class="input-wrapper"><i class="ri-smartphone-line icon-left"></i><input type="tel" name="n_mobile" id="n_mobile" pattern="[0-9]{10}"></div></div>
                </div>

                <div id="family-form" class="form-section">
                    <span class="section-label">Primary Connection</span>
                    <div class="input-group">
                        <label>Primary Type</label>
                        <div class="input-wrapper">
                            <i class="ri-shield-user-line icon-left"></i>
                            <select name="p_type" id="p_type">
                                <option value="Existing">Existing (Active)</option>
                                <option value="NC">New Entry (NC)</option>
                                <option value="P2P">New Entry (P2P)</option>
                                <option value="MNP">New MNP - Metro</option>
                                <option value="NMNP">New NMNP - Non Metro</option>
                            </select>
                        </div>
                    </div>
                    <div class="input-group"><div class="input-wrapper"><i class="ri-user-star-line icon-left"></i><input type="text" name="p_name" placeholder="Primary Name"></div></div>
                    <div class="input-group"><div class="input-wrapper"><i class="ri-smartphone-line icon-left"></i><input type="tel" name="p_mobile" placeholder="Primary Mobile" pattern="[0-9]{10}"></div></div>

                    <div class="divider"><span>AND</span></div>

                    <span class="section-label">Secondary Connection (This SIM)</span>
                    <div class="input-group">
                        <label>Secondary Type</label>
                        <div class="input-wrapper">
                            <i class="ri-sim-card-line icon-left"></i>
                            <select name="s_type" id="s_type">
                                <option value="NC" selected>NC (Instant)</option>
                                <option value="P2P">P2P (Instant)</option>
                                <option value="MNP">MNP - Metro</option>
                                <option value="NMNP">NMNP - Non Metro</option>
                            </select>
                        </div>
                    </div>
                    <div class="input-group"><div class="input-wrapper"><i class="ri-user-smile-line icon-left"></i><input type="text" name="s_name" placeholder="Secondary Name"></div></div>
                    <div class="input-group"><div class="input-wrapper"><i class="ri-smartphone-line icon-left"></i><input type="tel" name="s_mobile" placeholder="Secondary Mobile" pattern="[0-9]{10}"></div></div>
                </div>

                <div class="input-group" style="margin-top: 20px;">
                    <label>Remarks</label>
                    <div class="input-wrapper">
                        <i class="ri-sticky-note-line icon-left"></i>
                        <input type="text" name="remarks" placeholder="Optional notes...">
                    </div>
                </div>

                <button type="submit" class="btn-submit">Save Record</button>
            </form>
        </div>
    </div>

    <div id="remarksModal" class="modal-overlay" style="display: none;">
        <div class="modal-card">
            <div class="modal-header">
                <h3><i class="ri-sticky-note-fill" style="color: var(--primary);"></i> Remarks</h3>
                <button onclick="closeRemarksModal()" class="icon-btn"><i class="ri-close-line"></i></button>
            </div>
            <div>
                <strong id="remarksTitle" style="color: var(--primary); font-size: 1.1rem; display:block; margin-bottom:5px;"></strong>
                <div id="remarksBody" class="remarks-content"></div>
            </div>
            <button onclick="closeRemarksModal()" class="btn-submit" style="background: var(--text-main); margin-top: 10px;">Close</button>
        </div>
    </div>

    <div class="bottom-nav">
        <a href="/" class="nav-item"><i class="ri-home-4-line"></i><span>Home</span></a>
        <a href="/all" class="nav-item active"><i class="ri-list-check-2"></i><span>All</span></a>
        <div class="nav-fab" onclick="openModal()"><i class="ri-add-line"></i></div>
        <a href="/manage" class="nav-item"><i class="ri-edit-2-line"></i><span>Edit</span></a>
        <a href="/analytics" class="nav-item"><i class="ri-pie-chart-line"></i><span>Analysis</span></a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        const modal = document.getElementById("addModal");
        const remarksModal = document.getElementById("remarksModal");
        
        const fpAdd = flatpickr("#customDate", { dateFormat: "Y-m-d", altInput: true, altFormat: "d/m/Y", allowInput: true, disableMobile: true });

        // Add Modal
        function openModal() { modal.style.display = 'flex'; setTimeout(() => { modal.classList.add('active'); }, 10); fpAdd.setDate(new Date()); handleCategoryChange(); }
        function closeModal() { modal.classList.remove('active'); setTimeout(() => { modal.style.display = 'none'; }, 300); }
        
        function handleCategoryChange() {
            const cat = document.getElementById('category').value;
            const normalForm = document.getElementById('normal-form');
            const familyForm = document.getElementById('family-form');
            normalForm.classList.remove('active'); familyForm.classList.remove('active');
            if (cat === 'Family') { familyForm.classList.add('active'); document.getElementById('n_name').required = false; document.getElementById('n_mobile').required = false; } 
            else { normalForm.classList.add('active'); document.getElementById('n_name').required = true; document.getElementById('n_mobile').required = true; }
        }

        // Remarks Modal
        function openRemarksModal(btn) {
            document.getElementById('remarksTitle').innerText = btn.getAttribute('data-name');
            document.getElementById('remarksBody').innerText = btn.getAttribute('data-remarks');
            remarksModal.style.display = 'flex';
            setTimeout(() => { remarksModal.classList.add('active'); }, 10);
        }
        function closeRemarksModal() { 
            remarksModal.classList.remove('active');
            setTimeout(() => { remarksModal.style.display = 'none'; }, 300);
        }

        window.onclick = function(event) { 
            if (event.target == modal) closeModal(); 
            if (event.target == remarksModal) closeRemarksModal(); 
        }
    </script>
</body>
</html>
