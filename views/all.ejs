<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>History</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="/style.css">
    <style>
        .form-section { display: none; }
        .form-section.active { display: block; animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
        .divider { height: 1px; background: #e2e8f0; margin: 20px 0; position: relative; }
        .divider span { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 0 10px; color: #64748b; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
        .section-label { font-size: 0.95rem; font-weight: 700; color: var(--primary); margin-bottom: 12px; display: block; }
        .flatpickr-input { background-color: #f8fafc !important; }
    </style>
</head>
<body>
    
    <nav class="navbar">
        <div class="logo">
            <i class="ri-history-line"></i> History<span class="highlight">Log</span>
        </div>
        <a href="#" class="logout-btn" onclick="openConfirmModal(event, '/logout', 'logout')"><i class="ri-logout-box-r-line"></i></a>
    </nav>

    <div class="container">
        <div class="section-title">
            <h2><i class="ri-file-list-3-line"></i> <%= headerTitle %></h2>
            <p class="subtitle">Complete verification history.</p>
        </div>

        <form action="/all" method="GET" class="filter-form">
            <div class="filter-wrapper">
                <i class="ri-filter-3-line"></i>
                <select name="month" class="filter-select" onchange="this.form.submit()">
                    <option value="0" <%= monthOffset == 0 ? 'selected' : '' %>>This Month</option>
                    <option value="1" <%= monthOffset == 1 ? 'selected' : '' %>>Last Month</option>
                    <option value="2" <%= monthOffset == 2 ? 'selected' : '' %>>2 Months Ago</option>
                    <option value="all" <%= monthOffset === 'all' ? 'selected' : '' %>>Show All History</option>
                </select>
            </div>
        </form>

        <div class="grid-layout">
            <% customers.forEach(customer => { %>
                <div class="card" style="<%= (customer.category !== 'Family' && customer.status === 'completed') ? 'opacity: 0.8;' : '' %>">
                     <div class="card-top">
                        <div style="display: flex; gap: 5px;">
                            <% if (customer.category === 'Family') { %>
                                <span class="badge badge-Family">Family</span>
                            <% } else { %>
                                <span class="badge badge-<%= customer.category %>"><%= customer.category %></span>
                            <% } %>
                        </div>
                        <span class="date-tag"><%= new Date(customer.activationDate || customer.createdAt).toLocaleDateString('en-GB') %></span>
                    </div>

                    <% if (customer.category === 'Family') { %>
                        <div class="family-wrapper">
                            <div class="family-section primary-sec">
                                <span class="fs-label primary-label">Primary Connection 
                                    <% if (customer.primaryDoc) { %>
                                        <span class="badge badge-<%= customer.primaryDoc.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.primaryDoc.subType %></span>
                                    <% } else { %>
                                        <span class="badge" style="background:#e2e8f0; color:#475569; font-size: 0.6rem; padding: 2px 5px;">Existing</span>
                                    <% } %>
                                </span>
                                <div class="fs-info">
                                    <h4><%= customer.linkedPrimaryName || 'Unknown' %></h4>
                                    <p><%= customer.linkedPrimaryNumber %></p>
                                </div>
                                <div class="fs-actions">
                                    <a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a>
                                    <a href="tel:<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a>
                                    
                                    <span style="flex:1; text-align:center; font-size: 0.75rem; color: <%= (customer.primaryDoc && customer.primaryDoc.status === 'completed') ? '#10b981' : (customer.primaryDoc ? '#f59e0b' : '#10b981') %>; padding: 5px;">
                                        <%= (customer.primaryDoc && customer.primaryDoc.status === 'completed') ? '✅ Done' : (customer.primaryDoc ? '⏳ Pending' : '✅ Active') %>
                                    </span>
                                </div>
                            </div>
                            <div class="family-section secondary-sec">
                                <span class="fs-label secondary-label">Secondary (This SIM)
                                    <span class="badge badge-<%= customer.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.subType %></span>
                                </span>
                                <div class="fs-info">
                                    <h4 class="customer-name"><%= customer.name %></h4>
                                    <p class="mobile-txt"><%= customer.mobile %></p>
                                </div>
                                <div class="fs-actions">
                                    <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a>
                                    <a href="tel:<%= customer.mobile %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a>
                                    
                                    <span style="flex:1; text-align:center; font-size: 0.75rem; color: <%= customer.status === 'completed' ? '#10b981' : '#f59e0b' %>; padding: 5px;">
                                        <%= customer.status === 'completed' ? '✅ Done' : '⏳ Pending' %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="card-body">
                             <h3 class="customer-name"><%= customer.name %></h3>
                            <p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                        </div>
                        <div class="card-actions" style="margin-bottom: 8px;">
                            <a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp" style="flex: 1;"><i class="ri-whatsapp-line"></i> WhatsApp</a>
                            <a href="tel:<%= customer.mobile %>" class="btn-call" style="flex: 1;"><i class="ri-phone-fill"></i> Call</a>
                        </div>
                    <% } %>

                    <div class="card-actions" style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <% if (customer.remarks && customer.remarks.trim() !== "") { %>
                                <button class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)"><i class="ri-sticky-note-fill"></i> Note</button>
                            <% } %>
                        </div>
                        <% if (customer.category !== 'Family') { %>
                            <span style="font-size: 0.8rem; font-weight: 600; color: <%= customer.status === 'completed' ? '#10b981' : '#f59e0b' %>;">
                                <%= customer.status === 'completed' ? '✅ COMPLETED' : '⏳ PENDING' %>
                            </span>
                        <% } %>
                    </div>
                 </div>
            <% }) %>
        </div>
    </div>

    <div id="customConfirmModal" class="modal-overlay" style="display: none; z-index: 10000;">
        <div class="modal-card" style="text-align: center; max-width: 340px; padding: 30px 20px;">
            <div id="confirmIcon" class="confirm-icon"></div>
            <h3 id="confirmTitle" style="margin-bottom: 10px; font-size: 1.3rem;"></h3>
            <p id="confirmMessage" style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5;"></p>
            <div class="confirm-actions">
                <button type="button" class="btn-confirm-cancel" onclick="closeConfirmModal()">Cancel</button>
                <button type="button" id="confirmYesBtn" class="btn-confirm-yes">Yes</button>
            </div>
        </div>
    </div>

    <div class="bottom-nav">
        <a href="/" class="nav-item"><i class="ri-home-4-line"></i><span>Home</span></a>
        <a href="/all" class="nav-item active"><i class="ri-list-check-2"></i><span>All</span></a>
        <a href="/pdd" class="nav-item"><i class="ri-file-paper-2-line"></i><span>PDD</span></a>
        <div class="nav-fab" onclick="window.location.href='/'"><i class="ri-add-line"></i></div>
        <a href="/search" class="nav-item"><i class="ri-search-line"></i><span>Search</span></a>
        <a href="/manage" class="nav-item"><i class="ri-edit-2-line"></i><span>Edit</span></a>
        <a href="/analytics" class="nav-item"><i class="ri-pie-chart-line"></i><span>Analysis</span></a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        // --- CUSTOM CONFIRM MODAL LOGIC ---
        let formToSubmit = null;
        function openConfirmModal(event, element, actionType) {
            event.preventDefault();
            formToSubmit = element;
            
            const titleEl = document.getElementById('confirmTitle');
            const msgEl = document.getElementById('confirmMessage');
            const iconEl = document.getElementById('confirmIcon');
            const yesBtn = document.getElementById('confirmYesBtn');

            yesBtn.className = 'btn-confirm-yes';
            
            if (actionType === 'logout') {
                titleEl.innerText = "Secure Logout?";
                msgEl.innerText = "Are you sure you want to end your session?";
                iconEl.innerHTML = '<i class="ri-logout-circle-line" style="color: #ef4444;"></i>';
                yesBtn.classList.add('btn-confirm-danger');
                yesBtn.innerText = "Yes, Logout";
            }

            document.getElementById('customConfirmModal').style.display = 'flex';
            setTimeout(() => document.getElementById('customConfirmModal').classList.add('active'), 10);
        }

        function closeConfirmModal() {
            document.getElementById('customConfirmModal').classList.remove('active');
            setTimeout(() => document.getElementById('customConfirmModal').style.display = 'none', 300);
            formToSubmit = null;
        }

        document.getElementById('confirmYesBtn').addEventListener('click', function() {
            if (formToSubmit) {
                if (typeof formToSubmit === 'string') {
                    window.location.href = formToSubmit;
                } else {
                    formToSubmit.submit();
                }
            }
        });

        window.onclick = function(event) { if(event.target == document.getElementById('customConfirmModal')) closeConfirmModal(); }

        window.addEventListener('DOMContentLoaded', () => {
            const scrollPath = sessionStorage.getItem('scrollPath');
            const currentPath = window.location.pathname + window.location.search;
            if (scrollPath === currentPath) {
                const scrollPos = sessionStorage.getItem('scrollPos');
                if (scrollPos) setTimeout(() => window.scrollTo(0, parseInt(scrollPos)), 50);
            }
            sessionStorage.removeItem('scrollPos'); sessionStorage.removeItem('scrollPath');
        });
    </script>
</body>
</html>