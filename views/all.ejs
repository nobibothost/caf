<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'My Notes & Follow-ups' }) %>
    </head>
<body>
    <%- include('partials/top-nav', { icon: 'ri-sticky-note-line', title1: 'My', title2: 'Notes' }) %>

    <div id="app-main">
        <div class="container">
            <div class="section-title">
                <h2><i class="ri-edit-box-line"></i> <%= headerTitle %></h2>
                <p class="subtitle">Manage tasks, calls, and follow-ups.</p>
            </div>
            
            <div class="notes-container">
                <% if(notes.length === 0) { %>
                    <div style="text-align:center; padding: 40px 20px; background: white; border-radius: 20px; border: 1px dashed #cbd5e1; box-shadow: 0 10px 25px rgba(0,0,0,0.02);">
                        <div style="width: 80px; height: 80px; background: #e0e7ff; color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; margin: 0 auto 20px auto;"><i class="ri-book-3-line"></i></div>
                        <h3 style="margin: 0 0 10px 0; color: var(--text-main); font-size: 1.4rem;">No Notes Yet</h3>
                        <p style="margin: 0; color: var(--text-muted); font-size: 0.95rem;">Click the + button below to create your first note.</p>
                    </div>
                <% } else { %>
                    <% notes.forEach(note => { 
                        let catClass = 'cat-badge';
                        if(note.category.includes('NMNP')) catClass += ' cat-NMNP';
                        if(note.category.includes('MNP')) catClass += ' cat-MNP';
                        if(note.category.includes('PDD')) catClass += ' cat-PDD';
                        if(note.category.includes('Call')) catClass += ' cat-Call';

                        let targetMobile = '';
                        let targetName = '';
                        let targetId = '';
                        let isManual = false;

                        if (note.customerId) {
                            targetMobile = note.customerId.mobile;
                            targetName = note.customerId.name;
                            targetId = note.customerId._id;
                        } else if (note.manualMobile) {
                            targetMobile = note.manualMobile;
                            targetName = 'Manual Contact';
                            targetId = '';
                            isManual = true;
                        }
                    %>
                        <div class="note-card <%= note.isDone ? 'done' : '' %>">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <span class="<%= catClass %>"><%= note.category %></span>
                                <form action="/all/toggle/<%= note._id %>" method="POST" style="margin:0;">
                                    <button type="submit" style="background:transparent; border:none; color: <%= note.isDone ? '#10b981' : '#cbd5e1' %>; font-size: 1.5rem; cursor:pointer; padding:0;">
                                        <i class="<%= note.isDone ? 'ri-checkbox-circle-fill' : 'ri-checkbox-blank-circle-line' %>"></i>
                                    </button>
                                </form>
                            </div>
                            
                            <div class="note-text"><%= note.text %></div>
                            
                            <% if (targetMobile) { %>
                                <div style="background: <%= isManual ? 'rgba(139, 92, 246, 0.05)' : 'rgba(79, 70, 229, 0.05)' %>; border: 1px solid <%= isManual ? 'rgba(139, 92, 246, 0.1)' : 'rgba(79, 70, 229, 0.1)' %>; border-radius: 12px; padding: 12px; margin-top: 15px;">
                                    
                                    <div style="display: flex; justify-content: space-between; align-items: center;">
                                        <div>
                                            <h4 style="margin:0; font-size: 0.9rem; color: var(--text-main); font-weight: 600;"><%= targetName %></h4>
                                            <p style="margin:0; font-size: 0.8rem; color: var(--text-muted); font-family: monospace; letter-spacing: 0.5px; margin-top: 2px;"><i class="ri-phone-line"></i> <%= targetMobile %></p>
                                        </div>
                                        
                                        <div class="action-bar">
                                            <% if (targetId) { %>
                                                <a href="tel:8657973703,<%= targetMobile %>" class="action-btn btn-call" title="Direct Call" data-id="<%= targetId %>" data-page="normal" onclick="handleCallClick(event, this)">
                                                    <i class="ri-phone-fill"></i>
                                                </a>
                                            <% } else { %>
                                                <a href="tel:8657973703,<%= targetMobile %>" class="action-btn btn-call" title="Direct Call">
                                                    <i class="ri-phone-fill"></i>
                                                </a>
                                            <% } %>
                                            
                                            <button type="button" onclick="openWaModal('<%= targetMobile %>', '<%= targetName %>', 'normal')" class="action-btn btn-wa" title="Send WhatsApp">
                                                <i class="ri-whatsapp-fill"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <% if (note.customerId && note.customerId.callLogs && note.customerId.callLogs.length > 0) { %>
                                        <% const lc = note.customerId.callLogs[note.customerId.callLogs.length - 1]; %>
                                        <div class="last-call-tracker" style="margin-top: 10px; margin-bottom: 0; padding: 6px 10px; border-radius: 8px; font-size: 0.75rem; background: rgba(255,255,255,0.7); border-left: 3px solid var(--primary); display: flex; align-items: center; gap: 8px;">
                                            <i class="ri-phone-find-line" style="color: var(--primary); font-size: 0.9rem;"></i> 
                                            <span style="color: var(--text-main);">
                                                Last Call: <strong style="color: var(--text-main);"><%= lc.reason %></strong>
                                                <% if (lc.notes && lc.notes.trim() !== "") { %>
                                                    <span style="color: var(--text-muted);"> - <%= lc.notes %></span>
                                                <% } %>
                                            </span>
                                        </div>
                                    <% } %>
                                </div>
                            <% } %>
                            
                            <div class="note-meta">
                                <% 
                                    let d = new Date(note.createdAt); 
                                    let formattedDate = ('0' + d.getDate()).slice(-2) + '/' + ('0' + (d.getMonth() + 1)).slice(-2) + '/' + d.getFullYear();
                                %>
                                <span><i class="ri-calendar-line"></i> <%= formattedDate %></span>
                                <form action="/all/delete/<%= note._id %>" method="POST" style="margin:0;" onsubmit="return confirm('Delete this note permanently?');">
                                    <button type="submit" style="background:transparent; border:none; color: var(--danger); font-size: 1.1rem; cursor:pointer; padding:0;"><i class="ri-delete-bin-line"></i></button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <div class="add-note-fab" onclick="document.getElementById('addNoteModal').style.display='flex'; setTimeout(()=>document.getElementById('addNoteModal').classList.add('active'),10);">
            <i class="ri-add-line"></i>
        </div>

        <div id="addNoteModal" class="modal-overlay" style="display:none; z-index:9999;">
            <div class="modal-card">
                <div class="modal-header">
                    <h3><i class="ri-edit-box-line" style="color: var(--primary);"></i> Add New Note</h3>
                    <button type="button" onclick="this.closest('.modal-overlay').classList.remove('active'); setTimeout(()=>this.closest('.modal-overlay').style.display='none',300);" class="icon-btn"><i class="ri-close-line"></i></button>
                </div>
                <form action="/all/add" method="POST">
                    <div class="input-group">
                        <label>Note Content <span style="color:red">*</span></label>
                        <textarea name="text" rows="3" required placeholder="Write your follow-up, task, or reminder here..." style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 12px; font-family: 'Inter'; outline: none; resize: vertical;"></textarea>
                    </div>
                    
                    <div class="input-group">
                        <label>Category</label>
                        <div class="input-wrapper">
                            <i class="ri-price-tag-3-line icon-left"></i>
                            <select name="category" style="padding-left: 40px; border-radius: 12px; border: 1px solid var(--border); width: 100%; height: 45px; outline: none;">
                                <option value="General">General Task</option>
                                <option value="Follow-up">Follow-up</option>
                                <option value="NMNP Issue">NMNP Issue</option>
                                <option value="MNP Lead">MNP Lead</option>
                                <option value="PDD Collection">PDD Collection</option>
                                <option value="NC Pending">NC Pending</option>
                            </select>
                        </div>
                    </div>

                    <div class="input-group" style="position: relative; margin-bottom: 5px;">
                        <label>Link to Existing Customer</label>
                        <div id="selectedCustomerDisplay" class="selected-customer-pill">
                            <i class="ri-user-received-2-line"></i>
                            <span id="selectedCustomerName">Selected</span>
                            <i class="ri-close-circle-fill" style="cursor:pointer;" onclick="clearSelectedCustomer()"></i>
                        </div>
                        <div class="custom-search-container">
                            <i class="ri-search-2-line search-icon-fixed" id="searchIconDisplay"></i>
                            <input type="text" id="customerSearchInput" class="search-input-field" placeholder="Search by name or number..." autocomplete="off" oninput="filterCustomerList()">
                            <input type="hidden" name="customerId" id="selectedCustomerId">
                            <div id="searchResults" class="search-results-list"></div>
                        </div>
                    </div>

                    <div class="divider-text">OR</div>

                    <div class="input-group" style="margin-top: 5px;">
                        <label>Enter Manual Number</label>
                        <div class="input-wrapper" style="position: relative;">
                            <i class="ri-phone-line search-icon-fixed"></i>
                            <input type="tel" name="manualMobile" id="manualMobileInput" class="search-input-field" placeholder="e.g. 9876543210" pattern="[0-9]{10}" oninput="checkManualInput()">
                        </div>
                    </div>

                    <button type="submit" class="btn-submit" style="margin-top:20px;">Save Note <i class="ri-save-line"></i></button>
                </form>
            </div>
        </div>

        <%- include('partials/modals') %>
    </div> 
    
    <%- include('partials/bottom-nav', { page: 'all' }) %>
    
    <script>
        window.allPageCustomersData = <%- JSON.stringify(recentCustomers || []) %>;
    </script>
    
    <%- include('partials/scripts') %>
    
    <script src="/all.js"></script>
</body>
</html>