<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'All History' }) %>
</head>
<body>

    <%- include('partials/top-nav', { icon: 'ri-history-line', title1: 'All', title2: 'Data' }) %>

    <div id="app-main">
        <div class="container">
            <div class="section-title"><h2><i class="ri-list-check"></i> <%= headerTitle %></h2><p class="subtitle">Complete history of verifications.</p></div>

            <form action="/all" method="GET" class="filter-form"><div class="filter-wrapper"><i class="ri-filter-3-line"></i><select name="month" class="filter-select" onchange="handleFilterChange(event, this)"><option value="0" <%= monthOffset == 0 ? 'selected' : '' %>>This Month</option><option value="1" <%= monthOffset == 1 ? 'selected' : '' %>>Last Month</option><option value="2" <%= monthOffset == 2 ? 'selected' : '' %>>2 Months Ago</option><option value="all" <%= monthOffset === 'all' ? 'selected' : '' %>>Show All History</option></select></div></form>

            <div class="grid-layout" id="customerList" data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>">
                <% if (customers.length === 0) { %>
                    <div style="text-align: center; padding: 50px 20px; background: white; border-radius: 20px; border: 1px dashed #cbd5e1; margin-top: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.02); grid-column: 1 / -1;">
                        <div style="width: 80px; height: 80px; background: #e0e7ff; color: #4f46e5; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; margin: 0 auto 20px auto; box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.2);"><i class="ri-history-line"></i></div>
                        <h3 style="margin: 0 0 10px 0; color: #0f172a; font-size: 1.4rem;">No Records Found</h3><p style="margin: 0; color: #64748b; font-size: 0.95rem;">There is no history available for this period.</p>
                    </div>
                <% } else { %>
                    <% customers.forEach(customer => { %>
                        <div class="card search-item">
                            <div class="card-top">
                                <div style="display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                    <% if (customer.category === 'Family') { %> <span class="badge badge-Family">Family</span> <% } else { %> <span class="badge badge-<%= customer.category %>"><%= customer.category %></span> <% } %>
                                    <% if(customer.plan) { %><span class="badge" style="background: #f3f4f6; color: #475569; font-size: 0.65rem;">₹<%= customer.plan %></span><% } %>
                                    <% if (customer.status === 'completed') { %><span class="badge" style="background: #d1fae5; color: #059669;"><i class="ri-check-double-line"></i> Done</span><% } else { %><span class="badge" style="background: #fef3c7; color: #d97706;"><i class="ri-hourglass-2-fill"></i> Pending</span><% } %>
                                </div>
                                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                    <span style="font-size: 0.75rem; font-weight: 600; color: #64748b; background: #f1f5f9; padding: 2px 6px; border-radius: 4px;">Entry: <%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                    <span style="font-size: 0.75rem; font-weight: 600; color: var(--primary); background: #e0e7ff; padding: 2px 6px; border-radius: 4px;">Act: <%= new Date(new Date(customer.activationDate || customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                </div>
                            </div>
                            <% if (customer.category === 'Family') { %>
                                <div class="family-wrapper">
                                    <div class="family-section primary-sec">
                                        <span class="fs-label primary-label">Primary Connection <% if (customer.primaryDoc) { %><span class="badge badge-<%= customer.primaryDoc.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.primaryDoc.subType %></span><% } else { %><span class="badge" style="background:#e2e8f0; color:#475569; font-size: 0.6rem; padding: 2px 5px;">Existing</span><% } %></span>
                                        <div class="fs-info"><h4><%= customer.linkedPrimaryName || 'Unknown' %></h4><p><%= customer.linkedPrimaryNumber %></p></div>
                                        <div class="fs-actions"><a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a><a href="tel:<%= customer.linkedPrimaryNumber %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a></div>
                                    </div>
                                    <div class="family-section secondary-sec">
                                        <span class="fs-label secondary-label">Secondary (This SIM) <span class="badge badge-<%= customer.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.subType %></span></span>
                                        <div class="fs-info"><h4 class="customer-name"><%= customer.name %></h4><p class="mobile-txt"><%= customer.mobile %></p></div>
                                        <div class="fs-actions"><a href="whatsapp://send?phone=91<%= customer.mobile %>" class="mini-btn mini-wa"><i class="ri-whatsapp-line"></i></a><a href="tel:<%= customer.mobile %>" class="mini-btn mini-call"><i class="ri-phone-fill"></i></a></div>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="card-body"><h3 class="customer-name"><%= customer.name %></h3><p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p></div>
                                <div class="card-actions" style="margin-bottom: 8px;"><a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp" style="flex: 1;"><i class="ri-whatsapp-line"></i> WhatsApp</a><a href="tel:<%= customer.mobile %>" class="btn-call" style="flex: 1;"><i class="ri-phone-fill"></i> Call</a></div>
                            <% } %>
                            
                            <% if (customer.remarks && customer.remarks.trim() !== "") { %> 
                                <div class="card-actions">
                                    <button class="btn-note" style="width: 100%;" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)"><i class="ri-sticky-note-fill"></i> View Remarks</button> 
                                </div>
                            <% } %>
                        </div>
                    <% }) %>
                <% } %>
            </div>
            <div id="autoLoadSpinner" class="scroll-loader"><i class="ri-loader-4-line spin-loader"></i><br>Loading more...</div>
        </div>

        <%- include('partials/modals') %>
    </div> 
    
    <%- include('partials/bottom-nav', { page: page }) %>
    <%- include('partials/scripts') %>
</body>
</html>