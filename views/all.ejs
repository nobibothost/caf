<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'All Records' }) %>
</head>
<body>

    <%- include('partials/top-nav', { icon: 'ri-list-check', title1: 'All', title2: 'Records' }) %>

    <div id="app-main">
        <div class="container">
            <div class="section-title"><h2><i class="ri-history-line"></i> <%= headerTitle %></h2><p class="subtitle">Complete history of all entries.</p></div>

            <form action="/all" method="GET" class="filter-form" style="display: flex; gap: 10px; flex-wrap: wrap;">
                <div class="filter-wrapper" style="flex: 1; min-width: 140px;">
                    <i class="ri-filter-3-line"></i>
                    <select name="month" class="filter-select" onchange="handleFilterChange(event, this)">
                        <option value="0" <%= monthOffset == 0 ? 'selected' : '' %>>This Month</option>
                        <option value="1" <%= monthOffset == 1 ? 'selected' : '' %>>Last Month</option>
                        <option value="2" <%= monthOffset == 2 ? 'selected' : '' %>>2 Months Ago</option>
                        <option value="all" <%= monthOffset === 'all' ? 'selected' : '' %>>Show All History</option>
                        <option value="custom" <%= monthOffset === 'custom' ? 'selected' : '' %> style="display:none;">Custom Range</option>
                    </select>
                </div>
                <div class="filter-wrapper" style="flex: 1; min-width: 180px;">
                    <i class="ri-calendar-line"></i>
                    <input type="text" class="filter-select custom-range-picker" placeholder="Select Custom Range" value="<%= typeof daterange !== 'undefined' ? daterange : '' %>" readonly style="cursor: pointer; background: transparent; padding-left: 5px;">
                </div>
            </form>
            
            <div class="search-box"><i class="ri-search-line"></i><input type="text" id="searchInput" onkeyup="filterList()" placeholder="Quick filter on this page..."></div>

            <div class="grid-layout" id="customerList" data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>">
                <% if (customers.length === 0) { %>
                    <div style="text-align: center; padding: 50px 20px; background: white; border-radius: 20px; border: 1px dashed #cbd5e1; margin-top: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.02); grid-column: 1 / -1;">
                        <div style="width: 80px; height: 80px; background: #e0e7ff; color: #4f46e5; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; margin: 0 auto 20px auto; box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.2);"><i class="ri-folder-open-line"></i></div>
                        <h3 style="margin: 0 0 10px 0; color: #0f172a; font-size: 1.4rem;">No Records Found</h3><p style="margin: 0; color: #64748b; font-size: 0.95rem;">No history available for the selected period.</p>
                    </div>
                <% } else { %>
                    <% customers.forEach(customer => { 
                        let tintClass = "bg-tint-default";
                        let mainType = customer.category;
                        if (customer.isFamilyGroup || customer.category === 'Family') {
                            mainType = customer.triggerDoc ? customer.triggerDoc.subType : 'Family';
                        }
                        if (mainType === 'NC') tintClass = 'bg-tint-NC';
                        else if (mainType === 'P2P') tintClass = 'bg-tint-P2P';
                        else if (mainType === 'MNP') tintClass = 'bg-tint-MNP';
                        else if (mainType === 'NMNP') tintClass = 'bg-tint-NMNP';
                        else if (mainType === 'PDR') tintClass = 'bg-tint-PDR';
                        else if (mainType === 'Family' || mainType === 'Existing') tintClass = 'bg-tint-Family';
                    %>
                        <div class="card search-item <%= customer.isFamilyGroup ? 'bg-tint-Family' : tintClass %>" <%= customer.isFamilyGroup ? 'style="border-left: 4px solid #06b6d4 !important;"' : '' %>>
                            <div class="card-top">
                                <div style="display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                    <% if (customer.isFamilyGroup || customer.category === 'Family') { %> 
                                        <span class="badge badge-Family">Family</span> 
                                    <% } else { %> 
                                        <span class="badge badge-<%= customer.category %>"><%= customer.category %></span> 
                                    <% } %>
                                    <% if(customer.plan) { %><span class="badge" style="background: rgba(255, 255, 255, 0.7); color: #475569; font-size: 0.65rem; border: 1px solid rgba(0,0,0,0.05);">₹<%= customer.plan %></span><% } %>
                                    <% if (customer.billDate) { %><span class="badge" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;"><i class="ri-bill-line"></i> Bill: <%= customer.billDate %>th</span><% } %>
                                </div>
                                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                    <span style="font-size: 0.75rem; font-weight: 600; color: #64748b; background: rgba(255, 255, 255, 0.7); padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(0,0,0,0.05);">Entry: <%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                    <span style="font-size: 0.75rem; font-weight: 600; color: var(--primary); background: #e0e7ff; padding: 2px 6px; border-radius: 4px;">Act: <%= new Date(new Date(customer.activationDate || customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                </div>
                            </div>

                            <% if (customer.isFamilyGroup || customer.category === 'Family') { %>
                                <div class="family-wrapper" style="margin-bottom: 0; padding: 10px;">
                                    
                                    <% 
                                        let pBadge = 'Existing';
                                        if (customer.triggerDoc && customer.triggerDoc.subType && customer.triggerDoc.subType !== 'Existing') pBadge = customer.triggerDoc.subType;
                                        else if (customer.primary && customer.primary.subType && customer.primary.subType !== 'Existing') pBadge = customer.primary.subType;
                                        else if (customer.linkedPrimaryStatus && customer.linkedPrimaryStatus !== 'Existing' && customer.linkedPrimaryStatus !== '') pBadge = customer.linkedPrimaryStatus;
                                        else if (customer.subType && customer.subType !== 'Existing') pBadge = customer.subType;
                                    %>

                                    <div class="family-section primary-sec bg-tint-<%= pBadge === 'Existing' ? 'default' : pBadge %>" style="margin-bottom: 0; padding: 12px; border-radius: 12px; border-bottom: none; display: flex; flex-direction: column; gap: 10px;">
                                        
                                        <div style="display: flex; justify-content: space-between; align-items: center;">
                                            <span class="fs-label primary-label" style="color: var(--primary); margin: 0;">
                                                <% if (customer.triggerDoc && customer.triggerDoc.familyRole === 'Secondary') { %>
                                                    <i class="ri-user-add-line"></i> Add-on Connection <span class="badge badge-<%= customer.triggerDoc.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.triggerDoc.subType %></span>
                                                <% } else { %>
                                                    Primary Connection <span class="badge badge-<%= customer.triggerDoc ? customer.triggerDoc.subType : 'Existing' %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.triggerDoc ? customer.triggerDoc.subType : 'Existing' %></span>
                                                <% } %>
                                            </span>
                                        </div>

                                        <div class="fs-info" style="display: flex; justify-content: space-between; align-items: center;">
                                            <div>
                                                <h4 style="margin: 0; font-size: 1.05rem; color: #0f172a;"><%= customer.triggerDoc ? customer.triggerDoc.name : (customer.linkedPrimaryName || 'Existing Connection') %></h4>
                                                <p style="margin: 0; font-family: monospace; font-size: 0.85rem; color: #64748b;"><%= customer.triggerDoc ? customer.triggerDoc.mobile : customer.linkedPrimaryNumber %></p>
                                            </div>
                                        </div>

                                        <div class="card-actions" style="margin: 5px 0 0 0;">
                                            <a href="whatsapp://send?phone=91<%= customer.triggerDoc ? customer.triggerDoc.mobile : customer.linkedPrimaryNumber %>" class="btn-whatsapp" style="flex: 1; padding: 6px;"><i class="ri-whatsapp-line"></i> WhatsApp</a>
                                            <a href="tel:8657973703,<%= customer.triggerDoc ? customer.triggerDoc.mobile : customer.linkedPrimaryNumber %>" class="btn-call" style="flex: 1; padding: 6px;" data-id="<%= customer.triggerDoc ? customer.triggerDoc._id : customer._id %>" data-page="normal" onclick="handleCallClick(event, this)"><i class="ri-phone-fill"></i> Call</a>
                                        </div>
                                    </div>

                                    <button type="button" class="btn-theme btn-view-tree" data-tree-id="<%= customer._id.toString() %>" style="width: 100%; margin-top: 15px;">
                                        <i class="ri-team-fill" style="font-size: 1.1rem;"></i> View Full Family Tree (<%= (customer.secondaries ? customer.secondaries.length : 0) + 1 %>)
                                    </button>
                                    
                                    <div id="tree_data_<%= customer._id.toString() %>" style="display: none;">
                                        <div class="bg-tint-<%= pBadge === 'Existing' ? 'default' : pBadge %>" style="padding: 15px; border-radius: 12px; margin-bottom: 15px;">
                                            <div style="display:flex; justify-content: space-between; align-items: center;">
                                                <span class="fs-label" style="color: #475569; font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">
                                                    <i class="ri-star-fill" style="color: #eab308;"></i> Primary Account 
                                                    <% if(customer.primary){ %>
                                                        <span class="badge badge-<%= customer.primary.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.primary.subType %></span>
                                                    <% } else { %>
                                                        <span class="badge" style="background:#e2e8f0; color:#475569; font-size: 0.6rem; padding: 2px 5px;">Existing</span>
                                                    <% } %>
                                                </span>
                                                <span style="font-size: 0.65rem; font-weight: 600; color: var(--success); padding: 2px 0;">Status: <%= customer.primary ? customer.primary.status.toUpperCase() : 'ACTIVE' %></span>
                                            </div>
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                                                <div>
                                                    <h4 style="margin: 0; font-size: 1.1rem; color: #0f172a;"><%= customer.primary ? customer.primary.name : (customer.linkedPrimaryName && customer.linkedPrimaryName.trim() !== '' ? customer.linkedPrimaryName : 'Existing Connection') %></h4>
                                                    <p style="margin: 0; font-family: monospace; font-size: 0.9rem; color: #64748b;"><%= customer.linkedPrimaryNumber %></p>
                                                </div>
                                                <div style="display: flex; gap: 8px;">
                                                    <a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" class="icon-btn-round-wa large"><i class="ri-whatsapp-line"></i></a>
                                                    <a href="tel:8657973703,<%= customer.linkedPrimaryNumber %>" class="icon-btn-round-call large" onclick="handleCallClick(event, this)" data-id="<%= customer.primary ? customer.primary._id : 'N/A' %>" data-page="normal"><i class="ri-phone-fill"></i></a>
                                                </div>
                                            </div>
                                            <% if (pBadge !== 'Existing' && customer.primary) { %>
                                                <div style="margin-top: 12px; font-size: 0.75rem; color: #64748b; font-weight: 500; display: flex; gap: 12px; background: rgba(255,255,255,0.6); padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(0,0,0,0.05);">
                                                    <span><i class="ri-calendar-line"></i> Entry: <strong><%= new Date(new Date(customer.primary.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></strong></span>
                                                    <span style="color: var(--primary);"><i class="ri-flashlight-line"></i> Act Date: <strong><%= new Date(new Date(customer.primary.activationDate || customer.primary.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></strong></span>
                                                </div>
                                            <% } %>
                                        </div>

                                        <% if (customer.secondaries && customer.secondaries.length > 0) { %>
                                            <h5 style="margin: 0 0 10px 0; color: #64748b; font-size: 0.8rem; text-transform: uppercase;">Linked Add-ons (<%= customer.secondaries.length %>)</h5>
                                            <% customer.secondaries.forEach((sec, idx) => { %>
                                                <div class="bg-tint-<%= sec.subType === 'Existing' ? 'default' : sec.subType %>" style="padding: 15px; border-radius: 12px; margin-bottom: 15px;">
                                                    <div style="display:flex; justify-content: space-between; align-items: center;">
                                                        <span class="fs-label" style="color: #475569; font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">
                                                            <i class="ri-user-add-fill" style="color: var(--info);"></i> Secondary #<%= idx + 1 %> <span class="badge badge-<%= sec.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= sec.subType %></span>
                                                        </span>
                                                        <span style="font-size: 0.65rem; font-weight: 600; color: var(--success); padding: 2px 0;">Status: <%= sec.status.toUpperCase() %></span>
                                                    </div>
                                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                                                        <div>
                                                            <h4 style="margin: 0; font-size: 1.1rem; color: #0f172a;"><%= sec.name %></h4>
                                                            <p style="margin: 0; font-family: monospace; font-size: 0.9rem; color: #64748b;"><%= sec.mobile %></p>
                                                        </div>
                                                        <div style="display: flex; gap: 8px;">
                                                            <a href="whatsapp://send?phone=91<%= sec.mobile %>" class="icon-btn-round-wa large"><i class="ri-whatsapp-line"></i></a>
                                                            <a href="tel:8657973703,<%= sec.mobile %>" class="icon-btn-round-call large" onclick="handleCallClick(event, this)" data-id="<%= sec._id %>" data-page="normal"><i class="ri-phone-fill"></i></a>
                                                        </div>
                                                    </div>
                                                    <%
                                                        let finalSecActDate = sec.createdAt; 
                                                        if(sec.activationDate) finalSecActDate = sec.activationDate;
                                                    %>
                                                    <% if (sec.subType !== 'Existing') { %>
                                                        <div style="margin-top: 12px; font-size: 0.75rem; color: #64748b; font-weight: 500; display: flex; gap: 12px; background: rgba(255,255,255,0.6); padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(0,0,0,0.05);">
                                                            <span><i class="ri-calendar-line"></i> Entry: <strong><%= new Date(new Date(sec.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></strong></span>
                                                            <span style="color: var(--primary);"><i class="ri-flashlight-line"></i> Act: <strong><%= new Date(new Date(finalSecActDate).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></strong></span>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            <% }) %>
                                        <% } else { %>
                                            <p style="margin: 0; font-size: 0.85rem; color: #94a3b8; text-align: center; padding: 10px;">No add-on connections yet.</p>
                                        <% } %>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="card-body">
                                    <h3 class="customer-name"><%= customer.name %></h3>
                                    <p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                                    <p class="date-tag" style="margin-top:4px;"><i class="ri-calendar-line"></i> Entry: <%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></p>
                                </div>

                                <% if (customer.callLogs && customer.callLogs.length > 0) { %>
                                    <% const lc = customer.callLogs[customer.callLogs.length - 1]; %>
                                    <div class="last-call-tracker" style="margin-top: 12px; margin-bottom: 8px;">
                                        <i class="ri-phone-find-line"></i> 
                                        <span>Last Call: <%= new Intl.DateTimeFormat('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', hour12: true }).format(new Date(lc.callDate)) %> - <strong><%= lc.reason %></strong></span>
                                    </div>
                                <% } %>

                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; margin-top: 15px;">
                                    <button type="button" class="btn-whatsapp" style="margin: 0; width: 100%;" onclick="openWaModal('<%= customer.mobile %>', '<%= customer.name %>', 'verification', '<%= customer.gender || '' %>')">
                                        <i class="ri-whatsapp-line"></i> WhatsApp
                                    </button>
                                    <a href="tel:8657973703,<%= customer.mobile %>" class="btn-call" style="margin: 0; width: 100%;" data-id="<%= customer._id %>" data-page="verification" onclick="handleCallClick(event, this)">
                                        <i class="ri-phone-fill"></i> Call
                                    </a>
                                </div>

                                <% let hasRemarks = (customer.remarks && customer.remarks.trim() !== ""); %>
                                <% let isPending = (customer.status !== 'completed'); %>
                                
                                <% if (hasRemarks || isPending) { %>
                                    <div style="display: grid; grid-template-columns: <%= (hasRemarks && isPending) ? '1fr 1fr' : '1fr' %>; gap: 10px;">
                                        <% if (hasRemarks) { %> 
                                            <button type="button" class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)" style="margin: 0; width: 100%;">
                                                <i class="ri-sticky-note-fill"></i> Remarks
                                            </button> 
                                        <% } %>
                                        
                                        <% if (isPending) { %>
                                            <form action="/complete/<%= customer._id %>" method="POST" style="margin: 0;" onsubmit="openConfirmModal(event, this, 'done')">
                                                <button type="submit" class="btn-done" style="margin: 0; width: 100%; height: 100%; padding: 10px;">
                                                    <i class="ri-check-line" style="font-size: 1.1rem;"></i> Verify Done
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                <% } %>
                            <% } %>
                        </div>
                    <% }) %>
                <% } %>
            </div>
            <div id="autoLoadSpinner" class="scroll-loader"><i class="ri-loader-4-line spin-loader"></i><br>Loading more...</div>
        </div>

        <div id="familyTreeModal" class="modal-overlay" style="display:none; z-index:9999;">
            <div class="modal-card">
                <div class="modal-header">
                    <h3><i class="ri-team-fill" style="color: var(--primary);"></i> Full Family Tree</h3>
                    <button type="button" onclick="closeFamilyModal()" class="icon-btn"><i class="ri-close-line"></i></button>
                </div>
                <div id="familyTreeBody" style="padding:5px;"></div>
            </div>
        </div>

        <%- include('partials/modals') %>
    </div> 
    
    <%- include('partials/bottom-nav', { page: page }) %>
    <%- include('partials/scripts') %>
</body>
</html>