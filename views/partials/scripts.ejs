<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script src="/core.js"></script>
<script src="/modals.js"></script>
<script src="/calls.js"></script>
<script src="/forms.js"></script>
<script src="/features.js"></script>
<script src="/ai.js"></script>

<div id="agendaModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(15, 23, 42, 0.6); z-index:10000; align-items:center; justify-content:center; padding:20px; backdrop-filter: blur(4px); opacity: 0; transition: opacity 0.3s ease;">
    <div style="background:white; border-radius:20px; width:100%; max-width:380px; display:flex; flex-direction:column; box-shadow:0 25px 50px -12px rgba(0,0,0,0.5); overflow:hidden; transform: translateY(20px); transition: transform 0.3s ease;" id="agendaModalContent">
        <div style="padding:20px; background: linear-gradient(135deg, #eff6ff, #dbeafe); border-bottom:1px solid #bfdbfe; display:flex; justify-content:space-between; align-items:center;">
            <h3 style="margin:0; font-size:1.2rem; color:#1e40af; display: flex; align-items: center; gap: 8px;">
                <i class="ri-calendar-todo-fill"></i> Today's Agenda
            </h3>
            <button type="button" onclick="toggleAgendaModal()" style="background:white; border:none; width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#3b82f6; box-shadow: 0 4px 6px rgba(0,0,0,0.05);"><i class="ri-close-line" style="font-size:1.4rem;"></i></button>
        </div>
        <div style="padding:20px;">
            <div id="agenda-verifications" style="display:flex; align-items:center; gap: 15px; padding: 15px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; margin-bottom: 12px; cursor: pointer; transition: background 0.2s;" onclick="handleAgendaClick('verifications')" onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='#f8fafc'">
                <div style="width: 45px; height: 45px; background: #e0e7ff; color: #4f46e5; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;"><i class="ri-shield-check-fill"></i></div>
                <div style="flex: 1;">
                    <h4 style="margin: 0; font-size: 1rem; color: #0f172a;">Pending Verifications</h4>
                    <p style="margin: 0; font-size: 0.85rem; color: #64748b;" id="agenda-ver-text">Loading...</p>
                </div>
                <i class="ri-arrow-right-s-line" style="color: #cbd5e1; font-size: 1.5rem;"></i>
            </div>

            <div id="agenda-bills" style="display:flex; align-items:center; gap: 15px; padding: 15px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 12px; cursor: pointer; transition: background 0.2s;" onclick="handleAgendaClick('bills')" onmouseover="this.style.background='#fef3c7'" onmouseout="this.style.background='#fffbeb'">
                <div style="width: 45px; height: 45px; background: #fef3c7; color: #d97706; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;"><i class="ri-bill-fill"></i></div>
                <div style="flex: 1;">
                    <h4 style="margin: 0; font-size: 1rem; color: #92400e;">Pending Bills (PDD)</h4>
                    <p style="margin: 0; font-size: 0.85rem; color: #b45309;" id="agenda-bill-text">Loading...</p>
                </div>
                <i class="ri-arrow-right-s-line" style="color: #fcd34d; font-size: 1.5rem;"></i>
            </div>
        </div>
    </div>
</div>

<script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js').then(reg => {
                console.log('SW Registered', reg);
            }).catch(err => console.error('SW Reg Failed:', err));
        });
    }

    async function fetchAgenda() {
        try {
            const res = await fetch('/api/agenda');
            const data = await res.json();
            
            let ackVerCount = parseInt(localStorage.getItem('ackVerCount')) || 0;
            let ackBillCount = parseInt(localStorage.getItem('ackBillCount')) || 0;

            let unreadVer = data.pendingVerifications;
            if (data.pendingVerifications <= ackVerCount) {
                unreadVer = 0; 
                localStorage.setItem('ackVerCount', data.pendingVerifications);
            }

            let unreadBill = data.pendingBills;
            if (data.pendingBills <= ackBillCount) {
                unreadBill = 0;
                localStorage.setItem('ackBillCount', data.pendingBills);
            }

            let totalUnread = unreadVer + unreadBill;
            const badge = document.getElementById('bell-badge');
            if(totalUnread > 0) {
                badge.innerText = totalUnread > 99 ? '99+' : totalUnread;
                badge.style.display = 'flex';
                badge.style.animation = 'pulse 2s infinite';
            } else {
                badge.style.display = 'none';
            }

            document.getElementById('agenda-ver-text').innerHTML = data.pendingVerifications > 0 
                ? `<strong style="color:#ef4444">${data.pendingVerifications}</strong> verifications due.` 
                : "All caught up!";
            document.getElementById('agenda-bill-text').innerHTML = data.pendingBills > 0 
                ? `<strong style="color:#dc2626">${data.pendingBills}</strong> bills pending.` 
                : "No pending bills!";
            window.currentAgendaVerifications = data.pendingVerifications;
            window.currentAgendaBills = data.pendingBills;

        } catch(e) { console.error("Agenda Fetch Error:", e); }
    }

    function handleAgendaClick(type) {
        if (type === 'verifications') {
            localStorage.setItem('ackVerCount', window.currentAgendaVerifications || 0);
            window.location.href = '/';
        } else if (type === 'bills') {
            localStorage.setItem('ackBillCount', window.currentAgendaBills || 0);
            window.location.href = '/pdd';
        }
    }

    function toggleAgendaModal() {
        const modal = document.getElementById('agendaModal');
        const content = document.getElementById('agendaModalContent');
        if(modal.style.display === 'none') {
            modal.style.display = 'flex';
            void modal.offsetWidth;
            modal.style.opacity = '1';
            content.style.transform = 'translateY(0)';
        } else {
            modal.style.opacity = '0';
            content.style.transform = 'translateY(20px)';
            setTimeout(() => { modal.style.display = 'none'; }, 300);
        }
    }

    document.getElementById('agendaModal').addEventListener('click', function(e) {
        if(e.target === this) toggleAgendaModal();
    });
    
    document.addEventListener('DOMContentLoaded', fetchAgenda);

    const originalSubmit = HTMLFormElement.prototype.submit;
    HTMLFormElement.prototype.submit = function() {
        const actionUrl = this.getAttribute('action') || '';
        if (actionUrl.includes('/complete/') || actionUrl.includes('/pay-bill') || actionUrl.includes('/pay-all-bills')) {
            const duration = 1200;
            const end = Date.now() + duration;
            (function frame() {
                confetti({
                    particleCount: 6,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0, y: 0.6 },
                    colors: ['#10b981', '#3b82f6', '#f59e0b']
                });
                confetti({
                    particleCount: 6,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1, y: 0.6 },
                    colors: ['#10b981', '#3b82f6', '#f59e0b']
                });
                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());
            setTimeout(() => {
                originalSubmit.call(this);
            }, duration + 100);
        } else {
            originalSubmit.call(this);
        }
    };

    // ==========================================
    // 🔥 PREMIUM SUCCESS TOAST SYSTEM 🔥
    // ==========================================
    function getCookie(name) {
        let matches = document.cookie.match(new RegExp("(?:^|; )" + name.replace(/([\.$?*|{}\(\)\[\]\\\/\+^])/g, '\\$1') + "=([^;]*)"));
        return matches ? decodeURIComponent(matches[1]) : undefined;
    }
    
    function eraseCookie(name) {
        document.cookie = name + '=; Max-Age=-99999999; path=/';
    }
    
    function showPremiumToast(message) {
        let container = document.getElementById('hub-toast-container');
        if(!container) {
            container = document.createElement('div');
            container.id = 'hub-toast-container';
            container.style.cssText = 'position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%); z-index: 11500; display: flex; flex-direction: column; gap: 10px; align-items: center; pointer-events: none;';
            document.body.appendChild(container);
        }
        
        const toast = document.createElement('div');
        toast.style.cssText = 'background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); color: #fff; padding: 12px 24px; border-radius: 50px; font-size: 0.95rem; font-family: "Inter", sans-serif; font-weight: 500; box-shadow: 0 10px 25px rgba(0,0,0,0.25); opacity: 0; transform: translateY(20px); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.15); pointer-events: auto;';
        
        // Pick icon based on message content
        let iconHtml = '<i class="ri-checkbox-circle-fill" style="color: #10b981; font-size: 1.2rem;"></i>';
        if (message.includes('Deleted')) iconHtml = '<i class="ri-delete-bin-fill" style="color: #ef4444; font-size: 1.2rem;"></i>';
        else if (message.includes('Updated')) iconHtml = '<i class="ri-edit-circle-fill" style="color: #3b82f6; font-size: 1.2rem;"></i>';
        
        toast.innerHTML = `${iconHtml} <span>${message}</span>`;
        container.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
        }, 10);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 400);
        }, 3500);
    }

    // Check for cookie on load and trigger toast
    document.addEventListener('DOMContentLoaded', () => {
        const toastMsg = getCookie('hubToast');
        if (toastMsg) {
            showPremiumToast(toastMsg);
            eraseCookie('hubToast');
        }
    });
</script>

<style>
    @keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
        70% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
        100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }
    .notification-bell:hover { background: #e2e8f0 !important; }
</style>