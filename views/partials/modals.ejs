<div id="addModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3>New Verification</h3>
            <button onclick="closeModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <form action="/add" method="POST" id="addForm">
            <%- include('form-fields', { isEdit: false }) %>
            <button type="submit" class="btn-submit">Save Record</button>
        </form>
    </div>
</div>

<div id="editModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Edit Record</h3>
            <button onclick="closeEditModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <form id="editForm" method="POST">
            <%- include('form-fields', { isEdit: true }) %>
            <button type="submit" class="btn-submit">Update Record</button>
        </form>
        <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">
        <form id="deleteForm" method="POST" onsubmit="openConfirmModal(event, this, 'delete')">
            <button type="submit" class="btn-delete"><i class="ri-delete-bin-line"></i> Delete Full Entry</button>
        </form>
    </div>
</div>

<div id="remarksModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="ri-sticky-note-fill" style="color: var(--primary);"></i> Remarks</h3>
            <button onclick="closeRemarksModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <div>
            <strong id="remarksTitle" style="color: var(--primary); font-size: 1.1rem; display:block; margin-bottom:5px;"></strong>
            <div id="remarksBody" class="remarks-content"></div>
        </div>
        <button onclick="closeRemarksModal()" class="btn-submit" style="background: var(--text-main); margin-top: 10px;">Close</button>
    </div>
</div>

<div id="customConfirmModal" class="modal-overlay" style="display: none; z-index: 10000;">
    <div class="modal-card" style="text-align: center; padding: 30px 20px;">
        <div id="confirmIcon" class="confirm-icon"></div>
        <h3 id="confirmTitle" style="margin-bottom: 10px; font-size: 1.3rem;"></h3>
        <p id="confirmMessage" style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5;"></p>
        <div class="confirm-actions">
            <button type="button" class="btn-confirm-cancel" onclick="closeConfirmModal()">Cancel</button>
            <button type="button" id="confirmYesBtn" class="btn-confirm-yes">Yes</button>
        </div>
    </div>
</div>

<div id="waTemplateModal" class="modal-overlay" style="display: none; z-index: 10500;">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="ri-whatsapp-fill" style="color: #10b981;"></i> Quick Message</h3>
            <button onclick="closeWaModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <div id="waVerTemplates">
            <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 10px;">Select a message for pending verification:</p>
            <button class="wa-template-btn" data-text="Sir WhatsApp par check karna, verification ka message aaya hai kya." onclick="sendWaTemplate(this)">💬 Sir WhatsApp par check karna, verification ka message aaya hai kya.</button>
            <button class="wa-template-btn" data-text="Sir WhatsApp par verification ka message aaya hoga, check karna." onclick="sendWaTemplate(this)">💬 Sir WhatsApp par verification ka message aaya hoga, check karna.</button>
            <button class="wa-template-btn" data-text="Sir store se bol raha hoon Patel Nagar se, WhatsApp par verification ka message check karna." onclick="sendWaTemplate(this)">💬 Sir store se bol raha hoon Patel Nagar se, WhatsApp par verification ka message check karna.</button>
            <button class="wa-template-btn" data-text="Sir verification ke regarding koi message ya call aaya hai kya, check karna." onclick="sendWaTemplate(this)">💬 Sir verification ke regarding koi message ya call aaya hai kya, check karna.</button>
            <button class="wa-template-btn" data-text="Sir verification ka message ya call aaya hoga, check karna." onclick="sendWaTemplate(this)">💬 Sir verification ka message ya call aaya hoga, check karna.</button>
        </div>
        <div id="waPddTemplates" style="display: none;">
            <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 10px;">Select a message for pending bill payment:</p>
            <button class="wa-template-btn" data-text="Sir aapka bill {{billDate}} ko ban gaya hai, payment kar lena." onclick="sendWaTemplate(this)">💰 Sir aapka bill {{billDate}} ko ban gaya hai, payment kar lena.</button>
            <button class="wa-template-btn" data-text="Sir aapka bill {{billDate}} ko generate hua hai, abhi tak payment nahi kiya, payment kar lena." onclick="sendWaTemplate(this)">💰 Sir aapka bill {{billDate}} ko generate hua hai, abhi tak payment nahi kiya, payment kar lena.</button>
            <button class="wa-template-btn" data-text="Sir abhi tak payment nahi kiya hai, payment kar lena." onclick="sendWaTemplate(this)">⚠️ Sir abhi tak payment nahi kiya hai, payment kar lena.</button>
            <button class="wa-template-btn" data-text="Sir due date nikal chuki hai, abhi tak payment nahi kiya, payment kar lena." onclick="sendWaTemplate(this)">⚠️ Sir due date nikal chuki hai, abhi tak payment nahi kiya, payment kar lena.</button>
        </div>
    </div>
</div>