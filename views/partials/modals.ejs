<div id="addModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3>New Verification</h3>
            <button onclick="closeModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <form action="/add" method="POST" id="addForm">
            <%- include('form-fields', { isEdit: false }) %>
            <button type="submit" class="btn-submit">Save Record</button>
        </form>
    </div>
</div>

<div id="editModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Edit Record</h3>
            <button onclick="closeEditModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <form id="editForm" method="POST">
            <%- include('form-fields', { isEdit: true }) %>
            <button type="submit" class="btn-submit">Update Record</button>
        </form>
        <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">
        <form id="deleteForm" method="POST" onsubmit="openConfirmModal(event, this, 'delete')">
            <button type="submit" class="btn-delete"><i class="ri-delete-bin-line"></i> Delete Full Entry</button>
        </form>
    </div>
</div>

<div id="remarksModal" class="modal-overlay" style="display: none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="ri-sticky-note-fill" style="color: var(--primary);"></i> Remarks</h3>
            <button onclick="closeRemarksModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <div>
            <strong id="remarksTitle" style="color: var(--primary); font-size: 1.1rem; display:block; margin-bottom:5px;"></strong>
            <div id="remarksBody" class="remarks-content"></div>
        </div>
        <button onclick="closeRemarksModal()" class="btn-submit" style="background: var(--text-main); margin-top: 10px;">Close</button>
    </div>
</div>

<div id="customConfirmModal" class="modal-overlay" style="display: none; z-index: 10000;">
    <div class="modal-card" style="text-align: center; max-width: 340px; padding: 30px 20px;">
        <div id="confirmIcon" class="confirm-icon"></div>
        <h3 id="confirmTitle" style="margin-bottom: 10px; font-size: 1.3rem;"></h3>
        <p id="confirmMessage" style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5;"></p>
        <div class="confirm-actions">
            <button type="button" class="btn-confirm-cancel" onclick="closeConfirmModal()">Cancel</button>
            <button type="button" id="confirmYesBtn" class="btn-confirm-yes">Yes</button>
        </div>
    </div>
</div>

<div id="waTemplateModal" class="modal-overlay" style="display: none; z-index: 10500;">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="ri-whatsapp-fill" style="color: #10b981;"></i> Quick Message</h3>
            <button onclick="closeWaModal()" class="icon-btn"><i class="ri-close-line"></i></button>
        </div>
        <div id="waVerTemplates">
            <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 10px;">Select a message for pending verification:</p>
            <button class="wa-template-btn" data-text="Sir main Samshad from VI store Patel nagar se baat kar raha hu. Aapko msg aaya kya verification ke regarding?" onclick="sendWaTemplate(this)">💬 "Sir main Samshad from VI store..."</button>
            <button class="wa-template-btn" data-text="WhatsApp pr koi msg aya kya aapko verification ka?" onclick="sendWaTemplate(this)">💬 "WhatsApp pr msg aya kya verification ka?"</button>
            <button class="wa-template-btn" data-text="Koi call ya msg aaya kya verification ke regarding aapko?" onclick="sendWaTemplate(this)">💬 "Koi call ya msg aaya verification ke regarding?"</button>
            <button class="wa-template-btn" data-text="Verification kr liya aapne apne number ka?" onclick="sendWaTemplate(this)">💬 "Verification kr liya aapne apne number ka?"</button>
            <button class="wa-template-btn" data-text="Kripya apna tele-verification 59059 par call karke complete kar lijiye." onclick="sendWaTemplate(this)">📞 "Tele-verification 59059 par complete karein..."</button>
        </div>
        <div id="waPddTemplates" style="display: none;">
            <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 10px;">Select a message for pending bill payment:</p>
            <button class="wa-template-btn" data-text="Sir main Samshad from VI store Patel nagar se baat kar raha hu. Remind kar raha tha ki aapka bill {{billDate}} ko ban gaya hai, use due date se pehle pay karna hai." onclick="sendWaTemplate(this)">💰 Samshad: "Aapka bill {{billDate}} ko ban gaya hai..."</button>
            <button class="wa-template-btn" data-text="Aapka bill ban gaya hai. Kripya due date se pehle pay kar lijiye taaki service band na ho." onclick="sendWaTemplate(this)">💰 "Bill ban gaya hai, due date se pehle pay karlo..."</button>
            <button class="wa-template-btn" data-text="Aapka bill aa gaya hai. Payment karke screenshot share kar dijiye please." onclick="sendWaTemplate(this)">📸 "Bill aa gaya hai, pay karke screenshot bhejo..."</button>
            <button class="wa-template-btn" data-text="Aaj aapke bill ki due date hai. Late fee se bachne ke liye aaj hi pay kar dein." onclick="sendWaTemplate(this)">⚠️ "Aaj due date hai, late fee se bachne ke liye pay karein..."</button>
            <button class="wa-template-btn" data-text="Sir, agar aapne apna bill pay kar diya hai toh mujhe update kar dijiye." onclick="sendWaTemplate(this)">✅ "Agar bill pay kar diya hai toh update karein..."</button>
        </div>
    </div>
</div>