<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Global Search' }) %>
</head>
<body>

    <%- include('partials/top-nav', { icon: 'ri-search-eye-line', title1: 'Global', title2: 'Search' }) %>

    <div id="app-main">
        <div class="container">
            <div class="section-title" style="margin-bottom: 15px;"><h2><i class="ri-search-2-line"></i> Find Any Record</h2><p class="subtitle">Smart search by Name or Mobile across all months.</p></div>
         
            <div class="search-box" style="margin-bottom: 25px;"><form action="/search" method="GET" style="position: relative; width: 100%;" onsubmit="event.preventDefault();"><i id="searchIcon" class="ri-search-line" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 1.2rem; z-index: 2;"></i><i id="loadingIcon" class="ri-loader-4-line spin-loader" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--primary); font-size: 1.2rem; z-index: 2; display: none;"></i><input type="text" name="q" id="searchInput" value="<%= query %>" placeholder="Start typing Name or Mobile Number..." autocomplete="off" style="width: 100%; padding: 14px 20px 14px 45px; border: 1px solid var(--border); border-radius: 50px; font-size: 1rem; outline: none; box-shadow: 0 2px 5px rgba(0,0,0,0.02); transition: all 0.3s;" autofocus></form></div>

            <div id="searchResultsArea">
                <% if (query) { %><div style="margin-bottom: 15px; font-size: 0.9rem; color: #64748b;">Showing <%= totalItems %> results for "<strong><%= query %></strong>"</div><% } %>

                <div class="grid-layout" id="customerList" data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>">
                    <% if (query && customers.length === 0) { %>
                        <div style="text-align: center; padding: 50px 20px; background: white; border-radius: 20px; border: 1px dashed #cbd5e1; margin-top: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.02); grid-column: 1 / -1;">
                            <div style="width: 80px; height: 80px; background: #fae8ff; color: #8b5cf6; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; margin: 0 auto 20px auto; box-shadow: 0 10px 15px -3px rgba(139, 92, 246, 0.2);"><i class="ri-search-eye-line"></i></div>
                            <h3 style="margin: 0 0 10px 0; color: #0f172a; font-size: 1.4rem;">No Results Found</h3><p style="margin: 0; color: #64748b; font-size: 0.95rem;">Try searching with a different name or number.</p>
                        </div>
                    <% } else if (!query) { %>
                        <div style="text-align: center; padding: 50px 20px; background: transparent; grid-column: 1 / -1;">
                            <div style="color: #cbd5e1; font-size: 4.5rem; margin-bottom: 15px;"><i class="ri-keyboard-line"></i></div>
                            <h3 style="margin: 0 0 5px 0; color: #94a3b8; font-size: 1.2rem;">Type to start searching</h3>
                        </div>
                    <% } else { %>
                        <% customers.forEach(customer => { %>
                            <% if (customer.isFamilyGroup) { %>
                                <div class="card search-item" style="border: 2px solid #fbcfe8; background: white;">
                                    <div class="card-top">
                                        <div style="display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                            <span class="badge badge-Family">Family Group (<%= customer.secondaries.length %>)</span>
                                            <% if(customer.plan) { %><span class="badge" style="background: #f3f4f6; color: #475569; font-size: 0.65rem;">₹<%= customer.plan %></span><% } %>
                                            <% if (customer.billDate) { %><span class="badge" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;"><i class="ri-bill-line"></i> Bill: <%= customer.billDate %>th</span><% } %>
                                        </div>
                                        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                            <span style="font-size: 0.75rem; font-weight: 600; color: #64748b; background: #f1f5f9; padding: 2px 6px; border-radius: 4px;">Entry: <%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                            <span style="font-size: 0.75rem; font-weight: 600; color: var(--primary); background: #e0e7ff; padding: 2px 6px; border-radius: 4px;">Act: <%= new Date(new Date(customer.activationDate || customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                        </div>
                                    </div>
                        
                                    <div class="family-wrapper" style="margin-bottom: 0; padding: 10px;">
                                        <div class="family-section primary-sec" style="margin-bottom: 0; padding-bottom: 0; border-bottom: none;">
                                            <span class="fs-label primary-label">Primary Connection 
                                                <span class="badge" style="font-size: 0.6rem; padding: 2px 5px; background: #e2e8f0; color: #475569;"><%= customer.primary ? customer.primary.subType : 'Existing' %></span>
                                            </span>
                                            <div class="fs-info" style="display: flex; justify-content: space-between; align-items: center;">
                                                <div>
                                                    <h4 style="margin: 0; font-size: 1rem;"><%= customer.primary ? customer.primary.name : (customer.secondaries[0] ? customer.secondaries[0].linkedPrimaryName : 'Unknown') %></h4>
                                                    <p style="margin: 0; font-family: monospace; font-size: 0.85rem; color: #64748b;"><%= customer.linkedPrimaryNumber %></p>
                                                </div>
                                                <div style="display: flex; gap: 8px;">
                                                    <a href="whatsapp://send?phone=91<%= customer.linkedPrimaryNumber %>" style="width: 32px; height: 32px; background: #d1fae5; color: #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><i class="ri-whatsapp-line"></i></a>
                                                    <a href="tel:8657973703,<%= customer.linkedPrimaryNumber %>" style="width: 32px; height: 32px; background: #e2e8f0; color: #475569; border-radius: 50%; display: flex; align-items: center; justify-content: center;" onclick="handleCallClick(event, this)" data-id="<%= customer.primary ? customer.primary._id : customer.secondaries[0]._id %>" data-page="normal"><i class="ri-phone-fill"></i></a>
                                                </div>
                                            </div>
                                        </div>
                        
                                        <button type="button" id="family-btn-<%= customer.linkedPrimaryNumber %>" onclick="toggleFamily('<%= customer.linkedPrimaryNumber %>')" style="width: 100%; padding: 8px; background: #fdf2f8; border: 1px dashed #fbcfe8; color: #db2777; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; margin-top: 15px; display: flex; align-items: center; justify-content: center; gap: 5px;">
                                            <i class="ri-arrow-down-s-line" style="font-size: 1.1rem;"></i> Show <%= customer.secondaries.length %> Connections
                                        </button>
                                        
                                        <div id="family-list-<%= customer.linkedPrimaryNumber %>" style="display: none; margin-top: 15px;">
                                            <% customer.secondaries.forEach((sec, idx) => { %>
                                                <div style="padding-top: 10px; margin-top: 10px; border-top: 1px dashed #e2e8f0;">
                                                    <div style="display:flex; justify-content: space-between; align-items: center;">
                                                        <span class="fs-label secondary-label">Secondary #<%= idx + 1 %> <span class="badge badge-<%= sec.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= sec.subType %></span></span>
                                                    </div>
                                                    <div class="fs-info" style="display: flex; justify-content: space-between; align-items: center; margin-top: 5px;">
                                                        <div>
                                                            <h4 class="customer-name" style="margin: 0; font-size: 0.95rem;"><%= sec.name %></h4>
                                                            <p class="mobile-txt" style="margin: 0; font-size: 0.85rem;"><%= sec.mobile %></p>
                                                        </div>
                                                        <div style="display: flex; gap: 8px;">
                                                            <a href="whatsapp://send?phone=91<%= sec.mobile %>" style="border:none; width: 32px; height: 32px; background: #d1fae5; color: #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer;"><i class="ri-whatsapp-line"></i></a>
                                                            <a href="tel:8657973703,<%= sec.mobile %>" style="width: 32px; height: 32px; background: #e2e8f0; color: #475569; border-radius: 50%; display: flex; align-items: center; justify-content: center;" onclick="handleCallClick(event, this)" data-id="<%= sec._id %>" data-page="normal"><i class="ri-phone-fill"></i></a>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        </div>
                                    </div>
                        
                                    <div class="card-actions" style="margin-top: 12px;">
                                        <% if (customer.remarks && customer.remarks.trim() !== "") { %> <button class="btn-note" data-name="<%= customer.primary ? customer.primary.name : 'Family Group' %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)"><i class="ri-sticky-note-fill"></i></button> <% } %>
                                        <button class="btn-edit" 
                                            data-id="fam_<%= customer.linkedPrimaryNumber %>" 
                                            data-is-family="true"
                                            data-category="Family" 
                                            data-plan="<%= customer.plan || '' %>" 
                                            data-date="<%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0] %>" 
                                            data-remarks="<%= customer.remarks || '' %>" 
                                            data-p-name="<%= customer.primary ? customer.primary.name : (customer.secondaries[0] ? customer.secondaries[0].linkedPrimaryName : '') %>" 
                                            data-p-mobile="<%= customer.linkedPrimaryNumber %>" 
                                            data-p-status="<%= customer.primary ? customer.primary.subType : 'Existing' %>" 
                                            data-billdate="<%= customer.billDate || '' %>" 
                                            data-secondaries="<%= encodeURIComponent(JSON.stringify(customer.secondaries)) %>"
                                            onclick="openEditModal(this)">
                                            <i class="ri-pencil-line"></i> Manage Complete Family
                                        </button>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="card search-item">
                                    <div class="card-top">
                                        <div style="display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                            <span class="badge badge-<%= customer.category %>"><%= customer.category %></span>
                                            <% if(customer.plan) { %><span class="badge" style="background: #f3f4f6; color: #475569; font-size: 0.65rem;">₹<%= customer.plan %></span><% } %>
                                            <% if (customer.billDate) { %><span class="badge" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;"><i class="ri-bill-line"></i> Bill: <%= customer.billDate %>th</span><% } %>
                                        </div>
                                        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                            <span style="font-size: 0.75rem; font-weight: 600; color: #64748b; background: #f1f5f9; padding: 2px 6px; border-radius: 4px;">Entry: <%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                            <span style="font-size: 0.75rem; font-weight: 600; color: var(--primary); background: #e0e7ff; padding: 2px 6px; border-radius: 4px;">Act: <%= new Date(new Date(customer.activationDate || customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                        </div>
                                    </div>
                                    <div class="card-body"><h3 class="customer-name"><%= customer.name %></h3><p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p></div>
                                    <div class="card-actions" style="margin-bottom: 8px;"><a href="whatsapp://send?phone=91<%= customer.mobile %>" class="btn-whatsapp" style="flex: 1;"><i class="ri-whatsapp-line"></i> WhatsApp</a><a href="tel:8657973703,<%= customer.mobile %>" class="btn-call" style="flex: 1;"><i class="ri-phone-fill"></i> Call</a></div>
                                    <div class="card-actions">
                                        <% if (customer.remarks && customer.remarks.trim() !== "") { %> <button class="btn-note" data-name="<%= customer.name %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)"><i class="ri-sticky-note-fill"></i></button> <% } %>
                                        <button class="btn-edit" data-id="<%= customer._id %>" data-category="<%= customer.category %>" data-plan="<%= customer.plan || '' %>" data-date="<%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0] %>" data-remarks="<%= customer.remarks || '' %>" data-name="<%= customer.name %>" data-mobile="<%= customer.mobile %>" data-subtype="<%= customer.subType %>" data-p-name="<%= customer.linkedPrimaryName || '' %>" data-p-mobile="<%= customer.linkedPrimaryNumber || '' %>" data-p-status="<%= customer.primaryDoc ? customer.primaryDoc.subType : (customer.linkedPrimaryStatus || '') %>" data-billdate="<%= customer.billDate || '' %>" onclick="openEditModal(this)"><i class="ri-pencil-line"></i> Manage Data</button>
                                    </div>
                                </div>
                            <% } %>
                        <% }) %>
                    <% } %>
                </div>
                <div id="autoLoadSpinner" class="scroll-loader"><i class="ri-loader-4-line spin-loader"></i><br>Loading more...</div>
            </div>
        </div>

        <%- include('partials/modals') %>
    </div> 
    
    <%- include('partials/bottom-nav', { page: page }) %>
    <%- include('partials/scripts') %>
</body>
</html>