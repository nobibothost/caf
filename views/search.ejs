<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Global Search' }) %>
</head>
<body>

    <%- include('partials/top-nav', { icon: 'ri-search-eye-line', title1: 'Global', title2: 'Search' }) %>

    <div id="app-main">
        <div class="container">
            <div class="section-title" style="margin-bottom: 15px;"><h2><i class="ri-search-2-line"></i> Find Any Record</h2><p class="subtitle">Smart search by Name or Mobile across all months.</p></div>

            <div class="search-box" style="margin-bottom: 25px;">
                <form action="/search" method="GET" style="position: relative; width: 100%;" onsubmit="event.preventDefault();">
                    <i id="searchIcon" class="ri-search-line" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 1.2rem; z-index: 2;"></i>
                    <i id="loadingIcon" class="ri-loader-4-line spin-loader" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--primary); font-size: 1.2rem; z-index: 2; display: none;"></i>
                    <input type="text" name="q" id="globalSearchInput" value="<%= query %>" placeholder="Start typing Name or Mobile Number..." autocomplete="off" style="width: 100%; padding: 14px 20px 14px 45px; border: 1px solid var(--border); border-radius: 50px; font-size: 1rem; outline: none; box-shadow: 0 2px 5px rgba(0,0,0,0.02); transition: all 0.3s;" autofocus oninput="clearTimeout(window.liveSearchTimeout); document.getElementById('searchIcon').style.display='none'; document.getElementById('loadingIcon').style.display='block'; window.liveSearchTimeout = setTimeout(() => performLiveSearch(this.value), 400);">
                </form>
            </div>

            <div id="searchResultsArea">
                <% if (query) { %><div style="margin-bottom: 15px; font-size: 0.9rem; color: #64748b;">Showing <%= totalItems %> results for "<strong><%= query %></strong>"</div><% } %>

                <div class="grid-layout" id="customerList" data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>">
                    <% if (query && customers.length === 0) { %>
                        <div style="text-align: center; padding: 50px 20px; background: white; border-radius: 20px; border: 1px dashed #cbd5e1; margin-top: 10px; box-shadow: 0 10px 25px rgba(0,0,0,0.02); grid-column: 1 / -1;">
                            <div style="width: 80px; height: 80px; background: #fae8ff; color: #8b5cf6; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; margin: 0 auto 20px auto; box-shadow: 0 10px 15px -3px rgba(139, 92, 246, 0.2);"><i class="ri-search-eye-line"></i></div>
                            <h3 style="margin: 0 0 10px 0; color: #0f172a; font-size: 1.4rem;">No Results Found</h3><p style="margin: 0; color: #64748b; font-size: 0.95rem;">Try searching with a different name or number.</p>
                        </div>
                    <% } else if (!query) { %>
                        <div style="text-align: center; padding: 50px 20px; background: transparent; grid-column: 1 / -1;">
                            <div style="color: #cbd5e1; font-size: 4.5rem; margin-bottom: 15px;"><i class="ri-keyboard-line"></i></div>
                            <h3 style="margin: 0 0 5px 0; color: #94a3b8; font-size: 1.2rem;">Type to start searching</h3>
                        </div>
                    <% } else { %>
                        <% customers.forEach(customer => { 
                            
                            // 🔥 SMART PRIMARY FALLBACK LOGIC
                            let priGender = '';
                            let priStatus = 'Existing';
                            let priName = customer.linkedPrimaryName || '';
                            let priMobile = customer.linkedPrimaryNumber || '';
                            
                            if (customer.primary) {
                                priGender = customer.primary.gender || '';
                                priStatus = customer.primary.subType || 'Existing';
                                priName = customer.primary.name || priName;
                                priMobile = customer.primary.mobile || priMobile;
                            } else if (customer.triggerDoc && customer.triggerDoc.familyRole === 'Primary') {
                                priGender = customer.triggerDoc.gender || '';
                                priStatus = customer.triggerDoc.subType || 'Existing';
                                priName = customer.triggerDoc.name || priName;
                                priMobile = customer.triggerDoc.mobile || priMobile;
                            } else if (customer.category === 'Family' && customer.familyRole === 'Primary') {
                                priGender = customer.gender || '';
                                priStatus = customer.subType || 'Existing';
                                priName = customer.name || priName;
                                priMobile = customer.mobile || priMobile;
                            } else if (customer.linkedPrimaryStatus) {
                                priStatus = customer.linkedPrimaryStatus;
                            }

                            let tintClass = "bg-tint-default";
                            let mainType = customer.category;
                            if (customer.isFamilyGroup || customer.category === 'Family') {
                                mainType = customer.triggerDoc ? customer.triggerDoc.subType : 'Family';
                            }
                            if (mainType === 'NC') tintClass = 'bg-tint-NC';
                            else if (mainType === 'P2P') tintClass = 'bg-tint-P2P';
                            else if (mainType === 'MNP') tintClass = 'bg-tint-MNP';
                            else if (mainType === 'NMNP') tintClass = 'bg-tint-NMNP';
                            else if (mainType === 'Family' || mainType === 'Existing') tintClass = 'bg-tint-Family';
                        %>
                            <div class="card search-item <%= tintClass %>" <%= customer.isFamilyGroup ? 'style="border-left: 4px solid #db2777 !important;"' : '' %>>
                                <div class="card-top">
                                    <div style="display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                        <% if (customer.isFamilyGroup || customer.category === 'Family') { %> 
                                            <span class="badge badge-Family">Family</span> 
                                        <% } else { %> 
                                            <span class="badge badge-<%= customer.category %>"><%= customer.category %></span> 
                                        <% } %>
                                        <% if(customer.plan) { %><span class="badge" style="background: rgba(255, 255, 255, 0.7); color: #475569; font-size: 0.65rem; border: 1px solid rgba(0,0,0,0.05);">₹<%= customer.plan %></span><% } %>
                                        <% if (customer.billDate) { %><span class="badge" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;"><i class="ri-bill-line"></i> Bill: <%= customer.billDate %>th</span><% } %>
                                    </div>
                                    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                                        <span style="font-size: 0.75rem; font-weight: 600; color: #64748b; background: rgba(255, 255, 255, 0.7); padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(0,0,0,0.05);">Entry: <%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                        <span style="font-size: 0.75rem; font-weight: 600; color: var(--primary); background: #e0e7ff; padding: 2px 6px; border-radius: 4px;">Act: <%= new Date(new Date(customer.activationDate || customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %></span>
                                    </div>
                                </div>

                                <% if (customer.isFamilyGroup || customer.category === 'Family') { %>
                                    <div class="family-wrapper" style="margin-bottom: 0; padding: 10px;">
                                        <div class="family-section primary-sec" style="margin-bottom: 0; padding-bottom: 0; border-bottom: none; display: flex; flex-direction: column; gap: 10px;">
                                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                                <span class="fs-label primary-label" style="color: var(--primary); margin: 0;">
                                                    <% if (customer.triggerDoc && customer.triggerDoc.familyRole === 'Secondary') { %>
                                                        <i class="ri-user-add-line"></i> Add-on Connection <span class="badge badge-<%= customer.triggerDoc.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.triggerDoc.subType %></span>
                                                    <% } else { %>
                                                        Primary Connection <span class="badge badge-<%= customer.triggerDoc ? customer.triggerDoc.subType : 'Existing' %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.triggerDoc ? customer.triggerDoc.subType : 'Existing' %></span>
                                                    <% } %>
                                                </span>
                                            </div>

                                            <div class="fs-info" style="display: flex; justify-content: space-between; align-items: center;">
                                                <div>
                                                    <h4 style="margin: 0; font-size: 1.05rem; color: #0f172a;"><%= customer.triggerDoc ? customer.triggerDoc.name : (customer.linkedPrimaryName || 'Existing Connection') %></h4>
                                                    <p style="margin: 0; font-family: monospace; font-size: 0.85rem; color: #64748b;"><%= customer.triggerDoc ? customer.triggerDoc.mobile : customer.linkedPrimaryNumber %></p>
                                                </div>
                                                <div style="display: flex; gap: 8px;">
                                                    <button type="button" onclick="openWaModal('<%= customer.triggerDoc ? customer.triggerDoc.mobile : customer.linkedPrimaryNumber %>', '<%= customer.triggerDoc ? customer.triggerDoc.name : (customer.linkedPrimaryName || 'Existing Connection') %>', 'normal', '<%= customer.triggerDoc ? customer.triggerDoc.gender : (customer.gender || '') %>')" style="border:none; width: 32px; height: 32px; background: #d1fae5; color: #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer;"><i class="ri-whatsapp-line"></i></button>
                                                    <a href="tel:8657973703,<%= customer.triggerDoc ? customer.triggerDoc.mobile : customer.linkedPrimaryNumber %>" style="width: 32px; height: 32px; background: rgba(255,255,255,0.8); color: #475569; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(0,0,0,0.1);" onclick="handleCallClick(event, this)" data-id="<%= customer.triggerDoc ? customer.triggerDoc._id : customer._id %>" data-page="normal"><i class="ri-phone-fill"></i></a>
                                                </div>
                                            </div>
                                        </div>

                                        <div style="display: flex; gap: 8px; margin-top: 15px;">
                                            <button type="button" onclick="window.openFamilyModal('<%= customer._id.toString() %>')" style="flex: 1; padding: 10px 5px; background: rgba(253, 242, 248, 0.8); border: 1px dashed #fbcfe8; color: #db2777; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 5px; transition: all 0.2s ease;">
                                                <i class="ri-team-fill" style="font-size: 1.1rem;"></i> View Tree
                                            </button>

                                            <button type="button" class="btn-edit" style="flex: 1; padding: 10px 5px; background: rgba(240, 253, 244, 0.8); border: 1px dashed #bbf7d0; color: #16a34a; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 5px; transition: all 0.2s ease;"
                                                data-id="fam_<%= customer.linkedPrimaryNumber %>" 
                                                data-is-family="true"
                                                data-category="Family" 
                                                data-plan="<%= customer.plan || '' %>" 
                                                data-date="<%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0] %>" 
                                                data-remarks="<%= customer.remarks || '' %>" 
                                                data-p-name="<%= priName %>" 
                                                data-p-mobile="<%= priMobile %>" 
                                                data-p-status="<%= priStatus %>" 
                                                data-p-gender="<%= priGender %>"
                                                data-billdate="<%= customer.billDate || '' %>" 
                                                data-secondaries="<%= encodeURIComponent(JSON.stringify(customer.secondaries)) %>"
                                                onclick="openEditModal(this)">
                                                <i class="ri-pencil-line" style="font-size: 1.1rem;"></i> Manage Family
                                            </button>
                                        </div>
                                        
                                        <div id="tree_data_<%= customer._id.toString() %>" style="display: none;">
                                            <div style="padding-bottom: 15px; border-bottom: 2px dashed #e2e8f0; margin-bottom: 15px;">
                                                <div style="display:flex; justify-content: space-between; align-items: center;">
                                                    <span class="fs-label" style="color: #475569; font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">
                                                        <i class="ri-star-fill" style="color: #eab308;"></i> Primary Account 
                                                        <% if(customer.primary){ %>
                                                            <span class="badge badge-<%= customer.primary.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= customer.primary.subType %></span>
                                                        <% } else { %>
                                                            <span class="badge" style="background:#e2e8f0; color:#475569; font-size: 0.6rem; padding: 2px 5px;">Existing</span>
                                                        <% } %>
                                                    </span>
                                                    <span style="font-size: 0.65rem; font-weight: 600; color: #4f46e5; padding: 2px 0;">Status: <%= customer.primary ? customer.primary.status.toUpperCase() : 'ACTIVE' %></span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                                                    <div>
                                                        <h4 style="margin: 0; font-size: 1.1rem; color: #0f172a;"><%= customer.primary ? customer.primary.name : (customer.linkedPrimaryName && customer.linkedPrimaryName.trim() !== '' ? customer.linkedPrimaryName : 'Existing Connection') %></h4>
                                                        <p style="margin: 0; font-family: monospace; font-size: 0.9rem; color: #64748b;"><%= customer.linkedPrimaryNumber %></p>
                                                    </div>
                                                    <div style="display: flex; gap: 8px;">
                                                        <button type="button" onclick="openWaModal('<%= customer.linkedPrimaryNumber %>', '<%= customer.primary ? customer.primary.name : (customer.linkedPrimaryName || 'Existing Connection') %>', 'normal', '<%= customer.primary ? customer.primary.gender : '' %>')" style="border:none; width: 38px; height: 38px; background: #d1fae5; color: #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 1.2rem;"><i class="ri-whatsapp-line"></i></button>
                                                        <a href="tel:8657973703,<%= customer.linkedPrimaryNumber %>" style="width: 38px; height: 38px; background: #e2e8f0; color: #475569; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;" onclick="handleCallClick(event, this)" data-id="<%= customer.primary ? customer.primary._id : 'N/A' %>" data-page="normal"><i class="ri-phone-fill"></i></a>
                                                    </div>
                                                </div>
                                            </div>

                                            <% if (customer.secondaries && customer.secondaries.length > 0) { %>
                                                <h5 style="margin: 0 0 10px 0; color: #64748b; font-size: 0.8rem; text-transform: uppercase;">Linked Add-ons (<%= customer.secondaries.length %>)</h5>
                                                <% customer.secondaries.forEach((sec, idx) => { %>
                                                    <div style="background: rgba(255, 255, 255, 0.7); padding: 12px; border-radius: 10px; border: 1px solid rgba(0,0,0,0.05); margin-bottom: 10px;">
                                                        <div style="display:flex; justify-content: space-between; align-items: center;">
                                                            <span class="fs-label" style="color: #475569; font-weight: 600; font-size: 0.75rem;">
                                                                Secondary #<%= idx + 1 %> <span class="badge badge-<%= sec.subType %>" style="font-size: 0.6rem; padding: 2px 5px;"><%= sec.subType %></span>
                                                            </span>
                                                            <span style="font-size: 0.65rem; font-weight: 600; color: #4f46e5; padding: 2px 0;">Status: <%= sec.status.toUpperCase() %></span>
                                                        </div>
                                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
                                                            <div>
                                                                <h4 style="margin: 0; font-size: 1rem; color: #0f172a;"><%= sec.name %></h4>
                                                                <p style="margin: 0; font-family: monospace; font-size: 0.85rem; color: #64748b;"><%= sec.mobile %></p>
                                                            </div>
                                                            <div style="display: flex; gap: 8px;">
                                                                <button type="button" onclick="openWaModal('<%= sec.mobile %>', '<%= sec.name %>', 'normal', '<%= sec.gender || '' %>')" style="border:none; width: 32px; height: 32px; background: #d1fae5; color: #059669; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer;"><i class="ri-whatsapp-line"></i></button>
                                                                <a href="tel:8657973703,<%= sec.mobile %>" style="width: 32px; height: 32px; background: #e2e8f0; color: #475569; border-radius: 50%; display: flex; align-items: center; justify-content: center;" onclick="handleCallClick(event, this)" data-id="<%= sec._id %>" data-page="normal"><i class="ri-phone-fill"></i></a>
                                                            </div>
                                                        </div>
                                                        <div style="margin-top: 8px; font-size: 0.7rem; color: #94a3b8; font-weight: 500;">
                                                            Entry Date: <%= new Date(new Date(sec.createdAt).getTime() + 330*60000).toISOString().split('T')[0].split('-').reverse().join('/') %>
                                                        </div>
                                                    </div>
                                                <% }) %>
                                            <% } else { %>
                                                <p style="margin: 0; font-size: 0.85rem; color: #94a3b8; text-align: center; padding: 10px;">No add-on connections yet.</p>
                                            <% } %>
                                        </div>
                                    </div>
                                <% } else { %>
                                    <div class="card-body">
                                        <h3 class="customer-name"><%= customer.name %></h3>
                                        <p class="meta-info mobile-txt"><i class="ri-smartphone-line"></i> <%= customer.mobile %></p>
                                    </div>
                                    <div class="card-actions" style="margin-bottom: 8px;">
                                        <button type="button" class="btn-whatsapp" style="flex: 1;" onclick="openWaModal('<%= customer.mobile %>', '<%= customer.name %>', 'normal', '<%= customer.gender || '' %>')"><i class="ri-whatsapp-line"></i> WhatsApp</button>
                                        <a href="tel:8657973703,<%= customer.mobile %>" class="btn-call" style="flex: 1;" data-id="<%= customer._id %>" data-page="normal" onclick="handleCallClick(event, this)"><i class="ri-phone-fill"></i> Call</a>
                                    </div>
                                    <div class="card-actions" style="margin-top: 8px;">
                                        <button type="button" class="btn-edit" style="width: 100%; padding: 10px; background: rgba(240, 253, 244, 0.8); border: 1px dashed #bbf7d0; color: #16a34a; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 5px; transition: all 0.2s ease;"
                                            data-id="<%= customer._id %>" 
                                            data-category="<%= customer.category %>" 
                                            data-plan="<%= customer.plan || '' %>" 
                                            data-date="<%= new Date(new Date(customer.createdAt).getTime() + 330*60000).toISOString().split('T')[0] %>" 
                                            data-remarks="<%= customer.remarks || '' %>" 
                                            data-name="<%= customer.name %>" 
                                            data-mobile="<%= customer.mobile %>" 
                                            data-subtype="<%= customer.subType %>" 
                                            data-gender="<%= customer.gender || '' %>"
                                            data-p-name="<%= priName %>" 
                                            data-p-mobile="<%= priMobile %>" 
                                            data-p-status="<%= priStatus %>" 
                                            data-p-gender="<%= priGender %>"
                                            data-billdate="<%= customer.billDate || '' %>" 
                                            onclick="openEditModal(this)">
                                            <i class="ri-pencil-line" style="font-size: 1.1rem;"></i> Manage Record
                                        </button>
                                    </div>
                                <% } %>
                                
                                <% if (customer.remarks && customer.remarks.trim() !== "") { %>
                                    <div class="card-actions" style="margin-top: 12px;">
                                        <button class="btn-note" data-name="<%= customer.triggerDoc ? customer.triggerDoc.name : (customer.name || (customer.primary ? customer.primary.name : 'Family Group')) %>" data-remarks="<%= customer.remarks %>" onclick="openRemarksModal(this)" style="width: 100%;"><i class="ri-sticky-note-fill"></i> View Remarks</button> 
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
                <div id="autoLoadSpinner" class="scroll-loader"><i class="ri-loader-4-line spin-loader"></i><br>Loading more...</div>
            </div>
        </div>

        <div id="familyTreeModal" class="modal-overlay" style="display:none; z-index:9999;">
            <div class="modal-card">
                <div class="modal-header">
                    <h3><i class="ri-team-fill" style="color: var(--primary);"></i> Full Family Tree</h3>
                    <button type="button" onclick="window.closeFamilyModal()" class="icon-btn"><i class="ri-close-line"></i></button>
                </div>
                <div id="familyTreeBody" style="padding:5px;"></div>
            </div>
        </div>

        <%- include('partials/modals') %>
    </div> 
    
    <%- include('partials/bottom-nav', { page: page }) %>
    <%- include('partials/scripts') %>
</body>
</html>